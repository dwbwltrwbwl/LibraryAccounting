<UserControl x:Class="LibraryAccounting.Models.BookLocationMap"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="400" d:DesignWidth="600">
    <UserControl.Resources>
        <!-- Стиль для обычной полки -->
        <Style x:Key="ShelfStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFDF9"/>
            <Setter Property="BorderBrush" Value="#C8BFAF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Width" Value="80"/>
            <Setter Property="Height" Value="100"/>
        </Style>

        <!-- Стиль для полки с книгой -->
        <Style x:Key="ShelfWithBookStyle" TargetType="Border" BasedOn="{StaticResource ShelfStyle}">
            <Setter Property="Background" Value="#D4E8D4"/>
            <Setter Property="BorderBrush" Value="#2F4F4F"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>

        <!-- Стиль для полки с просроченной книгой -->
        <Style x:Key="OverdueShelfStyle" TargetType="Border" BasedOn="{StaticResource ShelfStyle}">
            <Setter Property="Background" Value="#FFD6D6"/>
            <Setter Property="BorderBrush" Value="#D32F2F"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>

        <!-- Стиль для заголовка ряда -->
        <Style x:Key="RowHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#2F4F4F"/>
            <Setter Property="Margin" Value="5,0,10,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <!-- Стиль для подсвеченной полки -->
        <Style x:Key="HighlightedShelfStyle" TargetType="Border" BasedOn="{StaticResource ShelfStyle}">
            <Setter Property="Background" Value="#FFEB96"/>
            <Setter Property="BorderBrush" Value="#FFC107"/>
            <Setter Property="BorderThickness" Value="3"/>
        </Style>
    </UserControl.Resources>

    <Border Background="#FFFDF9" BorderBrush="#C8BFAF" BorderThickness="1" CornerRadius="8" Padding="15">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <StackPanel Margin="0,0,0,15">
                <TextBlock Text="🗺️ Карта расположения книг" 
                           FontSize="16" FontWeight="SemiBold" Foreground="#2F4F4F"/>
                <TextBlock x:Name="BookInfoText" 
                           Text="" FontSize="12" Foreground="#6F6F6F" Margin="0,5,0,0"/>
            </StackPanel>

            <!-- Карта стеллажей -->
            <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" MaxHeight="350">
                <ItemsControl x:Name="ShelvesMapItemsControl">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#F4F1EC" CornerRadius="6" Margin="0,5">
                                <Grid Margin="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Название стеллажа -->
                                    <Border Background="#2F4F4F" CornerRadius="4" Padding="10,5" Margin="0,0,10,0">
                                        <TextBlock Text="{Binding ShelfName}" 
                                                   Foreground="White" FontWeight="Bold"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- Полки на стеллаже -->
                                    <ItemsControl Grid.Column="1" ItemsSource="{Binding Rows}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{Binding Style}" 
                                                        ToolTip="{Binding ToolTip}"
                                                        Cursor="Hand"
                                                        MouseLeftButtonDown="Shelf_Click">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding RowNumber}" 
                                                                   HorizontalAlignment="Center" 
                                                                   FontSize="12" FontWeight="Bold"
                                                                   Margin="5,5,5,0"/>
                                                        <TextBlock Text="{Binding BookCount}" 
                                                                   HorizontalAlignment="Center" 
                                                                   FontSize="10" Foreground="#6F6F6F"
                                                                   Margin="5,0,5,5"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Легенда -->
            <Border Grid.Row="2" Background="#F4F1EC" CornerRadius="6" Padding="10" Margin="0,15,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                        <Border Background="#D4E8D4" BorderBrush="#2F4F4F" BorderThickness="2" Width="20" Height="20" CornerRadius="3" Margin="0,0,5,0"/>
                        <TextBlock Text="Книга есть" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                        <Border Background="#FFFDF9" BorderBrush="#C8BFAF" BorderThickness="1" Width="20" Height="20" CornerRadius="3" Margin="0,0,5,0"/>
                        <TextBlock Text="Свободно" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Background="#FFD6D6" BorderBrush="#D32F2F" BorderThickness="1" Width="20" Height="20" CornerRadius="3" Margin="0,0,5,0"/>
                        <TextBlock Text="Просрочена" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
