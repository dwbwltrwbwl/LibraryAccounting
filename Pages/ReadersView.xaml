<Page x:Class="LibraryAccounting.Pages.ReadersView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d"
      d:DesignHeight="600"
      d:DesignWidth="1000"
      Background="#F4F1EC">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Border Background="#FFFDF9"
                BorderBrush="#C8BFAF"
                BorderThickness="1"
                CornerRadius="8"
                Padding="20"
                Margin="0,0,0,20">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Читатели"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="#2F4F4F"/>
                    <TextBlock Text="Учет зарегистрированных читателей"
                               FontSize="13"
                               Foreground="#6F6F6F"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <Button x:Name="AddButton" Content="Добавить"
                            Width="100"
                            Margin="0,0,10,0"
                            Style="{StaticResource ActionButtonStyle}"
                            Click="AddButton_Click"/>

                    <Button x:Name="DeleteButton" Content="Удалить"
                            Width="100"
                            Margin="0,0,10,0"
                            Style="{StaticResource ActionButtonStyle}"
                            Click="DeleteButton_Click"/>
                    <Button Content="Экспорт CSV"
                            Width="120"
                            Margin="0,0,10,0"
                            Style="{StaticResource ActionButtonStyle}"
                            Click="ExportButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Таблица читателей -->
        <Border Grid.Row="1"
                Background="#FFFDF9"
                BorderBrush="#C8BFAF"
                BorderThickness="1"
                CornerRadius="8"
                Padding="15">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal"
            Margin="0,0,0,10"
            VerticalAlignment="Center" Grid.Row="0">

                    <!-- Категория -->
                    <ComboBox x:Name="CategoryFilter"
              Width="150"
              Margin="0,0,10,0"
              SelectionChanged="FilterChanged">
                    </ComboBox>

                    <!-- Статус -->
                    <ComboBox x:Name="StatusFilter"
              Width="140"
              Margin="0,0,10,0"
              SelectionChanged="FilterChanged">
                        <ComboBoxItem Content="Все статусы" IsSelected="True"/>
                        <ComboBoxItem Content="Активный"/>
                        <ComboBoxItem Content="Заблокирован"/>
                    </ComboBox>

                    <!-- Книги -->
                    <ComboBox x:Name="BooksFilter"
              Width="160"
              Margin="0,0,10,0"
              SelectionChanged="FilterChanged">
                        <ComboBoxItem Content="Все"/>
                        <ComboBoxItem Content="Есть книги"/>
                        <ComboBoxItem Content="Нет книг"/>
                    </ComboBox>

                    <!-- Сортировка -->
                    <ComboBox x:Name="SortBox"
              Width="180"
              SelectionChanged="FilterChanged">
                        <ComboBoxItem Content="Без сортировки" IsSelected="True"/>
                        <ComboBoxItem Content="ФИО (А-Я)"/>
                        <ComboBoxItem Content="Дата регистрации"/>
                        <ComboBoxItem Content="Книг на руках"/>
                    </ComboBox>
                    <TextBlock Text="Поиск:"
           VerticalAlignment="Center"
           Foreground="#3A3A3A"
           Margin="0,0,10,0"/>

                    <TextBox x:Name="SearchTextBox"
         Width="250"
         Height="32"
         Padding="8"
         Background="#F4F1EC"
         BorderBrush="#C8BFAF"
         BorderThickness="1"
         TextChanged="SearchTextBox_TextChanged"/>
                </StackPanel>

                

                <!-- DataGrid -->
                <DataGrid x:Name="ReadersDataGrid"
                          IsReadOnly="True"
                          Grid.Row="1"
                          Style="{StaticResource BooksDataGridStyle}"
                          ColumnHeaderStyle="{StaticResource BooksDataGridColumnHeaderStyle}"
                          RowStyle="{StaticResource BooksDataGridRowStyle}"
                          CellStyle="{StaticResource BooksDataGridCellStyle}"
                          AutoGenerateColumns="False"
                          MouseDoubleClick="ReadersDataGrid_MouseDoubleClick">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="ФИО"
                                            Binding="{Binding FullName}"
                                            Width="2*"/>

                        <DataGridTextColumn Header="Телефон"
                                            Binding="{Binding Phone}"
                                            Width="1.2*"/>

                        <DataGridTextColumn Header="Email"
                                            Binding="{Binding Email}"
                                            Width="1.5*"/>

                        <DataGridTextColumn Header="Паспорт"
                                            Binding="{Binding PassportData}"
                                            Width="1.2*"/>

                        <DataGridTextColumn Header="Дата регистрации"
                                            Binding="{Binding RegistrationDate, StringFormat=d}"
                                            Width="1*"/>

                        <DataGridTextColumn Header="Дата рождения"
                    Binding="{Binding BirthDate, StringFormat=d}"
                    Width="1*"/>

                        <DataGridTextColumn Header="Категория"
                    Binding="{Binding Category}"
                    Width="1.2*"/>

                        <DataGridTextColumn Header="Книг на руках"
                    Binding="{Binding BooksOnHands}"
                    Width="1*"/>

                        <DataGridTextColumn Header="Статус"
                    Binding="{Binding Status}"
                    Width="1*"/>

                    </DataGrid.Columns>
                </DataGrid>

            </Grid>
        </Border>
    </Grid>
</Page>
