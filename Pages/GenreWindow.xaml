<Window x:Class="LibraryAccounting.Pages.GenreWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LibraryAccounting.Pages"
        mc:Ignorable="d"
        Title="Жанр" Height="500" Width="600"
        WindowStartupLocation="CenterOwner"
        Background="#F4F1EC">

    <Window.Resources>
        <!-- Стили остаются без изменений -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2F4F4F"/>
            <Setter Property="BorderBrush" Value="#1F3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1F3A3A"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#0F2A2A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CancelButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2F4F4F"/>
            <Setter Property="Background" Value="#FFFDF9"/>
            <Setter Property="BorderBrush" Value="#C8BFAF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0EDE8"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#E8E4DD"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TextFieldStyle" TargetType="TextBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Background" Value="#FFFDF9"/>
            <Setter Property="BorderBrush" Value="#C8BFAF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#2F4F4F"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="10,0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#2F4F4F"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MultiLineTextFieldStyle" TargetType="TextBox" BasedOn="{StaticResource TextFieldStyle}">
            <Setter Property="Height" Value="80"/>
            <Setter Property="VerticalContentAlignment" Value="Top"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        </Style>

        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Background" Value="#FFFDF9"/>
            <Setter Property="BorderBrush" Value="#C8BFAF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#2F4F4F"/>
            <Setter Property="Padding" Value="8,0"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2F4F4F"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="ErrorTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#D32F2F"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </Window.Resources>

    <Border Background="#FFFDF9"
            BorderBrush="#C8BFAF"
            BorderThickness="1"
            CornerRadius="10"
            Margin="15">

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Заголовок -->
                <TextBlock x:Name="TitleText" Text="Добавление / Редактирование жанра"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#2F4F4F"
                           Margin="0,0,0,20"
                           Grid.Row="0"/>

                <!-- Название -->
                <TextBlock Text="Название*" Grid.Row="1" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="NameBox" 
                         Grid.Row="2" 
                         Style="{StaticResource TextFieldStyle}"
                         MaxLength="100"
                         TextChanged="NameBox_TextChanged"/>

                <!-- Описание -->
                <TextBlock Text="Описание*" Grid.Row="3" Style="{StaticResource LabelStyle}" Margin="0,15,0,0"/>
                <TextBox x:Name="DescriptionBox" 
                         Grid.Row="4" 
                         Style="{StaticResource MultiLineTextFieldStyle}"
                         MaxLength="500"
                         TextChanged="DescriptionBox_TextChanged"/>

                <!-- Возрастной рейтинг -->
                <TextBlock Text="Возрастной рейтинг*" Grid.Row="5" Style="{StaticResource LabelStyle}" Margin="0,15,0,0"/>
                <ComboBox x:Name="AgeRatingBox" 
                          Grid.Row="6" 
                          Style="{StaticResource ComboBoxStyle}"
                          DisplayMemberPath="AgeRatingName"
                          SelectedValuePath="AgeRatingId"
                          SelectionChanged="AgeRatingBox_SelectionChanged"/>

                <!-- Блок ошибок -->
                <TextBlock x:Name="ErrorTextBlock" 
                           Grid.Row="7"
                           Style="{StaticResource ErrorTextStyle}"
                           Visibility="Collapsed"
                           Margin="0,15,0,10"/>

                <!-- Кнопки -->
                <StackPanel Grid.Row="8"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,10,0,0">
                    <Button Content="Сохранить" 
                            Width="120"
                            Style="{StaticResource ActionButtonStyle}"
                            Click="Save_Click"/>
                    <Button Content="Отмена" 
                            Width="120"
                            Style="{StaticResource CancelButtonStyle}"
                            Click="Cancel_Click"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Border>
</Window>