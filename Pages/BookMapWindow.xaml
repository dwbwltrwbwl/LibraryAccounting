<Window x:Class="LibraryAccounting.Windows.BookMapWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:LibraryAccounting.Models"
        Title="Карта расположения книг" Height="750" Width="1100"
        WindowStartupLocation="CenterOwner"
        Background="#F4F1EC">

    <Window.Resources>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2F4F4F"/>
            <Setter Property="BorderBrush" Value="#1F3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1F3A3A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#FFFDF9"/>
            <Setter Property="Foreground" Value="#2F4F4F"/>
            <Setter Property="BorderBrush" Value="#C8BFAF"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F4F1EC"/>
                    <Setter Property="BorderBrush" Value="#2F4F4F"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FilterButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
        </Style>

        <Style x:Key="TextFieldStyle" TargetType="TextBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Background" Value="#FFFDF9"/>
            <Setter Property="BorderBrush" Value="#C8BFAF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#2F4F4F"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="10,0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#2F4F4F"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Background" Value="#FFFDF9"/>
            <Setter Property="BorderBrush" Value="#C8BFAF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Поиск книги -->
        <Border Background="#FFFDF9" BorderBrush="#C8BFAF" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="🔍 Найти книгу:" VerticalAlignment="Center" 
                           Foreground="#2F4F4F" FontWeight="SemiBold" Margin="0,0,10,0"/>

                <TextBox x:Name="SearchBookTextBox" Grid.Column="1" Height="35" 
                         Style="{StaticResource TextFieldStyle}" 
                         TextChanged="SearchBookTextBox_TextChanged"/>

                <Button Content="Найти" Grid.Column="2" Width="80" Height="35" Margin="10,0,0,0"
                        Style="{StaticResource ActionButtonStyle}" Click="FindBook_Click"/>

                <Button Content="Сбросить" Grid.Column="3" Width="80" Height="35" Margin="10,0,0,0"
                        Style="{StaticResource SecondaryButtonStyle}" Click="ResetSearch_Click"/>
            </Grid>
        </Border>

        <!-- Фильтр по зонам -->
        <Border Grid.Row="1" Background="#FFFDF9" BorderBrush="#C8BFAF" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="📌 Фильтр по зоне:" VerticalAlignment="Center" 
                           Foreground="#2F4F4F" FontWeight="SemiBold" Margin="0,0,15,0"/>

                <ComboBox x:Name="ZoneFilterComboBox" Grid.Column="1" Width="250" 
                          Style="{StaticResource ComboBoxStyle}"
                          SelectionChanged="ZoneFilter_SelectionChanged">
                    <ComboBoxItem Content="Все зоны" IsSelected="True"/>
                    <ComboBoxItem Content="Зона A: Художественная литература"/>
                    <ComboBoxItem Content="Зона B: Научная литература"/>
                    <ComboBoxItem Content="Зона C: Техническая литература"/>
                    <ComboBoxItem Content="Зона D: Детская литература"/>
                    <ComboBoxItem Content="Зона E: Периодика и справочники"/>
                    <ComboBoxItem Content="Зона F: Иностранная литература"/>
                    <ComboBoxItem Content="Зона G: Искусство"/>
                    <ComboBoxItem Content="Зона H: История"/>
                    <ComboBoxItem Content="Зона I: Философия и психология"/>
                    <ComboBoxItem Content="Зона J: Право и экономика"/>
                </ComboBox>

                <Button Content="Обновить карту" Grid.Column="2" Width="120" Height="35" Margin="10,0,0,0"
                        Style="{StaticResource SecondaryButtonStyle}" Click="RefreshMap_Click"/>
            </Grid>
        </Border>

        <!-- Легенда -->
        <Border Grid.Row="2" Background="#FFFDF9" BorderBrush="#C8BFAF" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <WrapPanel HorizontalAlignment="Center">
                <Border Background="#D4E8D4" CornerRadius="4" Padding="10,5" Margin="5,0">
                    <TextBlock Text="🟢 Книга на руках (срок не истек)" FontSize="12" Foreground="#2E7D32"/>
                </Border>
                <Border Background="#FFD6D6" CornerRadius="4" Padding="10,5" Margin="5,0">
                    <TextBlock Text="🔴 Книга просрочена" FontSize="12" Foreground="#8B0000"/>
                </Border>
                <Border Background="#E8F5E9" CornerRadius="4" Padding="10,5" Margin="5,0">
                    <TextBlock Text="📚 Книга в библиотеке" FontSize="12" Foreground="#2E7D32"/>
                </Border>
                <Border Background="#FFFDF9" BorderBrush="#C8BFAF" BorderThickness="1" CornerRadius="4" Padding="10,5" Margin="5,0">
                    <TextBlock Text="⬜ Свободная полка" FontSize="12" Foreground="#6F6F6F"/>
                </Border>
                <Border Background="#FFEB96" CornerRadius="4" Padding="10,5" Margin="5,0">
                    <TextBlock Text="🟡 Найденная книга" FontSize="12" Foreground="#B8860B"/>
                </Border>
            </WrapPanel>
        </Border>

        <!-- Карта -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <ctrl:BookLocationMap x:Name="BookMap"/>
        </ScrollViewer>
    </Grid>
</Window>