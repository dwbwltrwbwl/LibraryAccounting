<Page x:Class="LibraryAccounting.Pages.DirectoriesView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:scm="clr-namespace:System.ComponentModel;assembly=WindowsBase"
      mc:Ignorable="d"
      Background="#F4F1EC">

    <Page.Resources>
        <!-- Стиль для основных кнопок -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2F4F4F"/>
            <Setter Property="BorderBrush" Value="#1F3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1F3A3A"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#0F2A2A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для DataGrid -->
        <Style x:Key="BooksDataGridStyle" TargetType="DataGrid">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#D4CFC8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#FFFDF9"/>
            <Setter Property="RowBackground" Value="#FFFDF9"/>
            <Setter Property="AlternatingRowBackground" Value="#F9F8F6"/>
            <Setter Property="VerticalGridLinesBrush" Value="#E8E4DD"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E8E4DD"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
        </Style>

        <!-- Стиль для заголовков колонок -->
        <Style x:Key="BooksDataGridColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Height" Value="45"/>
            <Setter Property="Background" Value="#2F4F4F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderBrush" Value="#1F3A3A"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- Стиль для строк -->
        <Style x:Key="BooksDataGridRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="#FFFDF9"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#D4E8E8"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0EDE8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для ячеек -->
        <Style x:Key="BooksDataGridCellStyle" TargetType="DataGridCell">
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#E8E4DD"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#D4E8E8"/>
                    <Setter Property="Foreground" Value="#1F3A3A"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===== ЗАГОЛОВОК ===== -->
        <Border Background="#FFFDF9"
                BorderBrush="#C8BFAF"
                BorderThickness="1"
                CornerRadius="10"
                Padding="20"
                Margin="0,0,0,20">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Справочники"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="#2F4F4F"/>

                    <TextBlock Text="Управление вспомогательными данными системы"
                               FontSize="13"
                               Foreground="#6F6F6F"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Экспорт CSV"
                        Width="120"
                        Style="{StaticResource ActionButtonStyle}"
                        Click="ExportCSV_Click"/>
            </Grid>
        </Border>

        <!-- ===== КОНТЕНТ ===== -->
        <Border Grid.Row="1"
                Background="#FFFDF9"
                BorderBrush="#C8BFAF"
                BorderThickness="1"
                CornerRadius="10"
                Padding="15">

            <TabControl x:Name="MainTabControl" SelectionChanged="TabControl_SelectionChanged">

                <!-- ===== ЖАНРЫ ===== -->
                <TabItem Header="Жанры">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Панель действий -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Button x:Name="AddGenre"
                                    Content="Добавить"
                                    Width="120"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Click="AddGenre_Click"/>

                            <Button x:Name="DeleteGenre"
                                    Content="Удалить"
                                    Width="120"
                                    Margin="10,0,0,0"
                                    Background="#5F3E40"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Click="DeleteGenre_Click"/>
                        </StackPanel>

                        <!-- Панель поиска -->
                        <Border Grid.Row="1"
                                Background="#F4F1EC"
                                CornerRadius="6"
                                Padding="10"
                                Margin="0,0,0,10">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Поиск:" VerticalAlignment="Center" 
                                           Foreground="#2F4F4F" FontWeight="SemiBold" Margin="0,0,10,0"/>
                                <TextBox x:Name="GenreSearchTextBox" 
                                         Width="250" 
                                         Height="30"
                                         TextChanged="GenreSearchTextBox_TextChanged"
                                         ToolTip="Поиск по названию и описанию жанра"/>
                            </StackPanel>
                        </Border>

                        <!-- Таблица -->
                        <Grid Grid.Row="2">
                            <DataGrid x:Name="GenresGrid"
                                      AutoGenerateColumns="False"
                                      MouseDoubleClick="GenresGrid_MouseDoubleClick"
                                      Sorting="GenresGrid_Sorting"
                                      CanUserSortColumns="True"
                                      Style="{StaticResource BooksDataGridStyle}"
                                      ColumnHeaderStyle="{StaticResource BooksDataGridColumnHeaderStyle}"
                                      RowStyle="{StaticResource BooksDataGridRowStyle}"
                                      CellStyle="{StaticResource BooksDataGridCellStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" 
                                                        Binding="{Binding GenreId}" 
                                                        Width="60"
                                                        SortMemberPath="GenreId"/>

                                    <DataGridTextColumn Header="Название жанра"
                                                        Binding="{Binding Name}"
                                                        Width="2*"
                                                        SortMemberPath="Name"/>

                                    <DataGridTextColumn Header="Описание"
                                                        Binding="{Binding Description}"
                                                        Width="3*"
                                                        SortMemberPath="Description"/>

                                    <DataGridTextColumn Header="Возрастной рейтинг"
                    Binding="{Binding AgeRatings.AgeRatingName}"
                    Width="1*"
                    SortMemberPath="AgeRating"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <StackPanel x:Name="GenresEmptyPanel"
                                        Visibility="Collapsed"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <TextBlock Text="😢" FontSize="40" HorizontalAlignment="Center"/>
                                <TextBlock Text="Ничего не найдено"
                                           FontSize="16"
                                           Foreground="#6F6F6F"
                                           HorizontalAlignment="Center"
                                           Margin="0,10,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </TabItem>

                <!-- ===== АВТОРЫ ===== -->
                <TabItem Header="Авторы">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Панель действий -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Button x:Name="AddAuthor"
                                    Content="Добавить"
                                    Width="120"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Click="AddAuthor_Click"/>

                            <Button x:Name="DeleteAuthor"
                                    Content="Удалить"
                                    Width="120"
                                    Margin="10,0,0,0"
                                    Background="#5F3E40"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Click="DeleteAuthor_Click"/>
                        </StackPanel>

                        <!-- Панель поиска -->
                        <Border Grid.Row="1"
                                Background="#F4F1EC"
                                CornerRadius="6"
                                Padding="10"
                                Margin="0,0,0,10">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Поиск:" VerticalAlignment="Center" 
                                           Foreground="#2F4F4F" FontWeight="SemiBold" Margin="0,0,10,0"/>
                                <TextBox x:Name="AuthorSearchTextBox" 
                                         Width="250" 
                                         Height="30"
                                         TextChanged="AuthorSearchTextBox_TextChanged"
                                         ToolTip="Поиск по ФИО, стране и городу автора"/>
                            </StackPanel>
                        </Border>

                        <!-- Таблица -->
                        <Grid Grid.Row="2">
                            <DataGrid x:Name="AuthorsGrid"
                                      AutoGenerateColumns="False"
                                      MouseDoubleClick="AuthorsGrid_MouseDoubleClick"
                                      Sorting="AuthorsGrid_Sorting"
                                      CanUserSortColumns="True"
                                      Style="{StaticResource BooksDataGridStyle}"
                                      ColumnHeaderStyle="{StaticResource BooksDataGridColumnHeaderStyle}"
                                      RowStyle="{StaticResource BooksDataGridRowStyle}"
                                      CellStyle="{StaticResource BooksDataGridCellStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" 
                                                        Binding="{Binding AuthorId}" 
                                                        Width="60"
                                                        SortMemberPath="AuthorId"/>

                                    <DataGridTextColumn Header="ФИО" 
                                                        Binding="{Binding FullName}" 
                                                        Width="2*"
                                                        SortMemberPath="FullName"/>

                                    <DataGridTextColumn Header="Дата рождения" 
                                                        Binding="{Binding BirthDate, StringFormat=d}" 
                                                        Width="1.2*"
                                                        SortMemberPath="BirthDate"/>

                                    <DataGridTextColumn Header="Дата смерти" 
                                                        Binding="{Binding DeathDate, StringFormat=d}" 
                                                        Width="1.2*"
                                                        SortMemberPath="DeathDate"/>

                                    <DataGridTextColumn Header="Страна" Binding="{Binding Cities.Countries.CountryName}" Width="1.5*" SortMemberPath="Country"/>
                                    <DataGridTextColumn Header="Город" 
                    Binding="{Binding Cities.CityName}" 
                    Width="2*"
                    SortMemberPath="City"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <StackPanel x:Name="AuthorsEmptyPanel"
                                        Visibility="Collapsed"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <TextBlock Text="😢" FontSize="40" HorizontalAlignment="Center"/>
                                <TextBlock Text="Ничего не найдено"
                                           FontSize="16"
                                           Foreground="#6F6F6F"
                                           HorizontalAlignment="Center"
                                           Margin="0,10,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </TabItem>

                <!-- ===== ИЗДАТЕЛЬСТВА ===== -->
                <TabItem Header="Издательства">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Панель действий -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Button x:Name="AddPublisher"
                                    Content="Добавить"
                                    Width="120"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Click="AddPublisher_Click"/>

                            <Button x:Name="DeletePublisher"
                                    Content="Удалить"
                                    Width="120"
                                    Margin="10,0,0,0"
                                    Background="#5F3E40"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Click="DeletePublisher_Click"/>
                        </StackPanel>

                        <!-- Панель поиска -->
                        <Border Grid.Row="1"
                                Background="#F4F1EC"
                                CornerRadius="6"
                                Padding="10"
                                Margin="0,0,0,10">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Поиск:" VerticalAlignment="Center" 
                                           Foreground="#2F4F4F" FontWeight="SemiBold" Margin="0,0,10,0"/>
                                <TextBox x:Name="PublisherSearchTextBox" 
                                         Width="250" 
                                         Height="30"
                                         TextChanged="PublisherSearchTextBox_TextChanged"
                                         ToolTip="Поиск по названию и городу издательства"/>
                            </StackPanel>
                        </Border>

                        <!-- Таблица -->
                        <Grid Grid.Row="2">
                            <DataGrid x:Name="PublishersGrid"
                                      AutoGenerateColumns="False"
                                      MouseDoubleClick="PublishersGrid_MouseDoubleClick"
                                      Sorting="PublishersGrid_Sorting"
                                      CanUserSortColumns="True"
                                      Style="{StaticResource BooksDataGridStyle}"
                                      ColumnHeaderStyle="{StaticResource BooksDataGridColumnHeaderStyle}"
                                      RowStyle="{StaticResource BooksDataGridRowStyle}"
                                      CellStyle="{StaticResource BooksDataGridCellStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" 
                                                        Binding="{Binding PublisherId}" 
                                                        Width="60"
                                                        SortMemberPath="PublisherId"/>

                                    <DataGridTextColumn Header="Название издательства" 
                                                        Binding="{Binding PublisherName}" 
                                                        Width="3*"
                                                        SortMemberPath="PublisherName"/>

                                    <DataGridTextColumn Header="Город" 
                    Binding="{Binding Cities.CityName}" 
                    Width="2*"
                    SortMemberPath="City"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <StackPanel x:Name="PublishersEmptyPanel"
                                        Visibility="Collapsed"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <TextBlock Text="😢" FontSize="40" HorizontalAlignment="Center"/>
                                <TextBlock Text="Ничего не найдено"
                                           FontSize="16"
                                           Foreground="#6F6F6F"
                                           HorizontalAlignment="Center"
                                           Margin="0,10,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </TabItem>

            </TabControl>
        </Border>
    </Grid>
</Page>