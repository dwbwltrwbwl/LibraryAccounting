<Page x:Class="LibraryAccounting.Pages.DirectoriesView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:scm="clr-namespace:System.ComponentModel;assembly=WindowsBase"
      mc:Ignorable="d"
      Background="#F4F1EC">

    <Page.Resources>
        <!-- Стиль для основных кнопок -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2F4F4F"/>
            <Setter Property="BorderBrush" Value="#1F3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1F3A3A"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#0F2A2A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для DataGrid -->
        <Style x:Key="BooksDataGridStyle" TargetType="DataGrid">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#D4CFC8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#FFFDF9"/>
            <Setter Property="RowBackground" Value="#FFFDF9"/>
            <Setter Property="AlternatingRowBackground" Value="#F9F8F6"/>
            <Setter Property="VerticalGridLinesBrush" Value="#E8E4DD"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E8E4DD"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
        </Style>

        <!-- Стиль для заголовков колонок -->
        <Style x:Key="BooksDataGridColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Height" Value="45"/>
            <Setter Property="Background" Value="#2F4F4F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderBrush" Value="#1F3A3A"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- Стиль для строк -->
        <Style x:Key="BooksDataGridRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="#FFFDF9"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#D4E8E8"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0EDE8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для ячеек -->
        <Style x:Key="BooksDataGridCellStyle" TargetType="DataGridCell">
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#E8E4DD"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#D4E8E8"/>
                    <Setter Property="Foreground" Value="#1F3A3A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Шаблон заголовка группы -->
        <Style x:Key="GroupHeaderStyle" TargetType="GroupItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupItem">
                        <Expander IsExpanded="True" 
                                  Background="#F4F1EC" 
                                  BorderBrush="#C8BFAF" 
                                  BorderThickness="1" 
                                  Margin="0,2,0,2">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Name}" 
                                               FontWeight="Bold" 
                                               Foreground="#2F4F4F" 
                                               FontSize="14"
                                               Margin="5,5,0,5"/>
                                    <TextBlock Text=" (" 
                                               Foreground="#6F6F6F"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding ItemCount}" 
                                               Foreground="#6F6F6F"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text=")" 
                                               Foreground="#6F6F6F"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Expander.Header>
                            <ItemsPresenter Margin="20,5,0,5"/>
                        </Expander>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===== ЗАГОЛОВОК ===== -->
        <Border Background="#FFFDF9"
                BorderBrush="#C8BFAF"
                BorderThickness="1"
                CornerRadius="10"
                Padding="20"
                Margin="0,0,0,20">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Справочники"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="#2F4F4F"/>

                    <TextBlock Text="Управление вспомогательными данными системы"
                               FontSize="13"
                               Foreground="#6F6F6F"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Экспорт CSV"
                        Width="120"
                        Style="{StaticResource ActionButtonStyle}"
                        Click="ExportCSV_Click"/>
            </Grid>
        </Border>

        <!-- ===== КОНТЕНТ ===== -->
        <Border Grid.Row="1"
                Background="#FFFDF9"
                BorderBrush="#C8BFAF"
                BorderThickness="1"
                CornerRadius="10"
                Padding="15">

            <TabControl x:Name="MainTabControl" SelectionChanged="TabControl_SelectionChanged">

                <!-- ===== ЖАНРЫ ===== -->
                <TabItem Header="Жанры">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Панель действий -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Button x:Name="AddGenre"
                                    Content="Добавить"
                                    Width="120"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Click="AddGenre_Click"/>

                            <Button x:Name="DeleteGenre"
                                    Content="Удалить"
                                    Width="120"
                                    Margin="10,0,0,0"
                                    Background="#5F3E40"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Click="DeleteGenre_Click"/>
                        </StackPanel>

                        <!-- Панель фильтрации и группировки -->
                        <Border Grid.Row="1"
                                Background="#F4F1EC"
                                CornerRadius="6"
                                Padding="10"
                                Margin="0,0,0,10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Поиск -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="Поиск:" VerticalAlignment="Center" 
                                               Foreground="#2F4F4F" FontWeight="SemiBold" Margin="0,0,10,0"/>
                                    <TextBox x:Name="GenreSearchTextBox" 
                                             Width="250" 
                                             Height="30"
                                             TextChanged="GenreSearchTextBox_TextChanged"
                                             ToolTip="Поиск по названию жанра"/>

                                    <Button Grid.Column="1"
                                            Content="Сбросить поиск"
                                            Width="100"
                                            Height="30"
                                            Margin="10,0,0,0"
                                            Background="#FFFDF9"
                                            Foreground="#2F4F4F"
                                            BorderBrush="#C8BFAF"
                                            BorderThickness="1"
                                            Cursor="Hand"
                                            Click="ResetGenreSearch_Click"/>
                                </StackPanel>

                                <!-- Группировка -->
                                <StackPanel Grid.Row="1" Orientation="Horizontal">
                                    <TextBlock Text="Группировка:" VerticalAlignment="Center" 
                                               Foreground="#2F4F4F" FontWeight="SemiBold" Margin="0,0,10,0"/>
                                    <CheckBox x:Name="GenreGroupingCheckBox" 
                                              Content="Группировать по первой букве"
                                              VerticalAlignment="Center"
                                              Checked="GenreGroupingCheckBox_Checked"
                                              Unchecked="GenreGroupingCheckBox_Unchecked"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Таблица -->
                        <DataGrid x:Name="GenresGrid"
                                  Grid.Row="3"
                                  AutoGenerateColumns="False"
                                  MouseDoubleClick="GenresGrid_MouseDoubleClick"
                                  Sorting="GenresGrid_Sorting"
                                  CanUserSortColumns="True"
                                  Style="{StaticResource BooksDataGridStyle}"
                                  ColumnHeaderStyle="{StaticResource BooksDataGridColumnHeaderStyle}"
                                  RowStyle="{StaticResource BooksDataGridRowStyle}"
                                  CellStyle="{StaticResource BooksDataGridCellStyle}">
                            <DataGrid.Columns>

                                <DataGridTextColumn Header="ID" 
                        Binding="{Binding GenreId}" 
                        Width="60"
                        SortMemberPath="GenreId"/>

                                <DataGridTextColumn Header="Название жанра"
                        Binding="{Binding Name}"
                        Width="2*"
                        SortMemberPath="Name"/>

                                <DataGridTextColumn Header="Описание"
                        Binding="{Binding Description}"
                        Width="3*"/>

                                <DataGridTextColumn Header="Возраст"
                        Binding="{Binding AgeRating}"
                        Width="1*"
                        SortMemberPath="AgeRating"/>

                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!-- ===== АВТОРЫ ===== -->
                <TabItem Header="Авторы">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Панель действий -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Button x:Name="AddAuthor"
                                    Content="Добавить"
                                    Width="120"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Click="AddAuthor_Click"/>

                            <Button x:Name="DeleteAuthor"
                                    Content="Удалить"
                                    Width="120"
                                    Margin="10,0,0,0"
                                    Background="#5F3E40"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Click="DeleteAuthor_Click"/>
                        </StackPanel>

                        <!-- Панель фильтрации и группировки -->
                        <Border Grid.Row="1"
                                Background="#F4F1EC"
                                CornerRadius="6"
                                Padding="10"
                                Margin="0,0,0,10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Поиск -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="Поиск:" VerticalAlignment="Center" 
                                               Foreground="#2F4F4F" FontWeight="SemiBold" Margin="0,0,10,0"/>
                                    <TextBox x:Name="AuthorSearchTextBox" 
                                             Width="250" 
                                             Height="30"
                                             TextChanged="AuthorSearchTextBox_TextChanged"
                                             ToolTip="Поиск по ФИО автора"/>

                                    <Button Grid.Column="1"
                                            Content="Сбросить поиск"
                                            Width="100"
                                            Height="30"
                                            Margin="10,0,0,0"
                                            Background="#FFFDF9"
                                            Foreground="#2F4F4F"
                                            BorderBrush="#C8BFAF"
                                            BorderThickness="1"
                                            Cursor="Hand"
                                            Click="ResetAuthorSearch_Click"/>
                                </StackPanel>

                                <!-- Группировка -->
                                <StackPanel Grid.Row="1" Orientation="Horizontal">
                                    <TextBlock Text="Группировка:" VerticalAlignment="Center" 
                                               Foreground="#2F4F4F" FontWeight="SemiBold" Margin="0,0,10,0"/>
                                    <CheckBox x:Name="AuthorGroupingCheckBox" 
                                              Content="Группировать по первой букве"
                                              VerticalAlignment="Center"
                                              Checked="AuthorGroupingCheckBox_Checked"
                                              Unchecked="AuthorGroupingCheckBox_Unchecked"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Таблица -->
                        <DataGrid x:Name="AuthorsGrid"
                                  Grid.Row="3"
                                  AutoGenerateColumns="False"
                                  MouseDoubleClick="AuthorsGrid_MouseDoubleClick"
                                  Sorting="AuthorsGrid_Sorting"
                                  CanUserSortColumns="True"
                                  Style="{StaticResource BooksDataGridStyle}"
                                  ColumnHeaderStyle="{StaticResource BooksDataGridColumnHeaderStyle}"
                                  RowStyle="{StaticResource BooksDataGridRowStyle}"
                                  CellStyle="{StaticResource BooksDataGridCellStyle}">
                            <DataGrid.Columns>

                                <DataGridTextColumn Header="ID"
                        Binding="{Binding AuthorId}"
                        Width="60"
                        SortMemberPath="AuthorId"/>

                                <DataGridTextColumn Header="ФИО"
                        Binding="{Binding FullName}"
                        Width="2*"
                        SortMemberPath="FullName"/>

                                <DataGridTextColumn Header="Дата рождения"
                        Binding="{Binding BirthDate, StringFormat=d}"
                        Width="1.2*"
                        SortMemberPath="BirthDate"/>

                                <DataGridTextColumn Header="Дата смерти"
                        Binding="{Binding DeathDate, StringFormat=d}"
                        Width="1.2*"
                        SortMemberPath="DeathDate"/>

                                <DataGridTextColumn Header="Страна"
                        Binding="{Binding Country}"
                        Width="1.5*"
                        SortMemberPath="Country"/>

                                <DataGridTextColumn Header="Город"
                        Binding="{Binding City}"
                        Width="1.5*"
                        SortMemberPath="City"/>

                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <TabItem Header="Издательства">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Button Content="Добавить"
                    Width="120"
                    Style="{StaticResource ActionButtonStyle}"
                    Click="AddPublisher_Click"/>

                            <Button Content="Удалить"
                    Width="120"
                    Margin="10,0,0,0"
                    Background="#5F3E40"
                    Style="{StaticResource ActionButtonStyle}"
                    Click="DeletePublisher_Click"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="Поиск:" Margin="0,0,10,0"/>
                            <TextBox x:Name="PublisherSearchTextBox"
                     Width="250"
                     TextChanged="PublisherSearchTextBox_TextChanged"/>
                        </StackPanel>

                        <DataGrid x:Name="PublishersGrid"
                  Grid.Row="3"
                  AutoGenerateColumns="False"
                  MouseDoubleClick="PublishersGrid_MouseDoubleClick"
                  Style="{StaticResource BooksDataGridStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding PublisherId}" Width="60"/>
                                <DataGridTextColumn Header="Название" Binding="{Binding PublisherName}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

            </TabControl>
        </Border>
    </Grid>
</Page>