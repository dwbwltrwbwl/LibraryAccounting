<Page x:Class="LibraryAccounting.Pages.UserApprovalView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d"
      d:DesignHeight="700"
      d:DesignWidth="1200"
      Background="#F4F1EC">

    <Page.Resources>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2F4F4F"/>
            <Setter Property="BorderBrush" Value="#1F3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ApproveButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#4CAF50"/>
            <Setter Property="BorderBrush" Value="#388E3C"/>
        </Style>

        <Style x:Key="RejectButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#F44336"/>
            <Setter Property="BorderBrush" Value="#D32F2F"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Background="#FFFDF9"
                BorderBrush="#C8BFAF"
                BorderThickness="1"
                CornerRadius="10"
                Padding="20"
                Margin="0,0,0,20">

            <StackPanel>
                <TextBlock Text="Управление заявками"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="#2F4F4F"/>
                <TextBlock Text="Подтверждение регистрации новых сотрудников"
                           FontSize="13"
                           Foreground="#6F6F6F"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Таблица заявок -->
        <Border Grid.Row="1"
                Background="#FFFDF9"
                BorderBrush="#C8BFAF"
                BorderThickness="1"
                CornerRadius="10"
                Padding="15">

            <DataGrid x:Name="UsersDataGrid"
                      IsReadOnly="True"
                      AutoGenerateColumns="False"
                      Style="{StaticResource BooksDataGridStyle}"
                      ColumnHeaderStyle="{StaticResource BooksDataGridColumnHeaderStyle}"
                      RowStyle="{StaticResource BooksDataGridRowStyle}"
                      CellStyle="{StaticResource BooksDataGridCellStyle}"
                      SelectionChanged="UsersDataGrid_SelectionChanged">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding UserId}" Width="50"/>
                    <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="180"/>
                    <DataGridTextColumn Header="Логин" Binding="{Binding Login}" Width="120"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="150"/>
                    <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="120"/>
                    <DataGridTextColumn Header="Дата заявки" Binding="{Binding RequestDate, StringFormat=dd.MM.yyyy HH:mm}" Width="140"/>
                    <DataGridTextColumn Header="Стаж" Binding="{Binding Experience}" Width="60"/>
                    <DataGridTextColumn Header="Дата рождения" Binding="{Binding BirthDate, StringFormat=d}" Width="100"/>

                    <DataGridTemplateColumn Header="Действия" Width="180">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="✅ Одобрить" 
                                            Width="80" Height="28"
                                            Style="{StaticResource ApproveButtonStyle}"
                                            Click="ApproveUser_Click"
                                            Tag="{Binding UserId}"/>
                                    <Button Content="❌ Отклонить" 
                                            Width="80" Height="28"
                                            Margin="5,0,0,0"
                                            Style="{StaticResource RejectButtonStyle}"
                                            Click="RejectUser_Click"
                                            Tag="{Binding UserId}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>