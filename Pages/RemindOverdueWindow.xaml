<Window x:Class="LibraryAccounting.Pages.RemindOverdueWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Напоминание о просрочках" Height="600" Width="700"
        WindowStartupLocation="CenterOwner"
        Background="#F4F1EC">

    <Window.Resources>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2F4F4F"/>
            <Setter Property="BorderBrush" Value="#1F3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CancelButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#6F6F6F"/>
        </Style>
    </Window.Resources>

    <Border Background="#FFFDF9" BorderBrush="#C8BFAF" BorderThickness="1" CornerRadius="10" Margin="15">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <TextBlock Text="Выберите читателя для отправки напоминания"
                       FontSize="16" FontWeight="SemiBold" Foreground="#2F4F4F" Margin="0,0,0,15"/>

            <!-- Поиск -->
            <Border Grid.Row="1" Background="#F4F1EC" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="🔍 Поиск:" VerticalAlignment="Center" Foreground="#2F4F4F" FontWeight="SemiBold" Margin="0,0,10,0"/>
                    <TextBox x:Name="SearchBox" Grid.Column="1" Height="32" Padding="8" 
                             Background="#FFFDF9" BorderBrush="#C8BFAF" BorderThickness="1" 
                             TextChanged="SearchBox_TextChanged"/>
                </Grid>
            </Border>

            <!-- Список читателей -->
            <Border Grid.Row="2" Background="#F4F1EC" CornerRadius="6" Padding="5" Margin="0,0,0,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="📋 Список читателей с просрочкой:" 
                               Foreground="#2F4F4F" FontWeight="SemiBold" Margin="5,0,0,5"/>
                    <ListBox x:Name="ReadersListBox" Grid.Row="1" Height="180"
                             BorderBrush="#C8BFAF" BorderThickness="1" 
                             SelectionChanged="ReadersListBox_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8" Margin="2" CornerRadius="4" Background="#FFFDF9">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding FullName}" FontWeight="SemiBold" FontSize="13"/>
                                            <TextBlock Text="{Binding Email}" FontSize="11" Foreground="#6F6F6F"/>
                                        </StackPanel>
                                        <Border Grid.Column="1" Background="#FFEBEE" CornerRadius="10" 
                                                Padding="8,2" Margin="5,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding OverdueDays, StringFormat={}{0} дн.}"
                                                       FontSize="13" FontWeight="Bold" Foreground="#D32F2F"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Просроченные книги (скроллируемая область) -->
            <Border Grid.Row="3" Background="#F4F1EC" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="📚 Просроченные книги:" 
                               Foreground="#2F4F4F" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="150">
                        <TextBlock x:Name="SelectedReaderInfo" 
                                   Text="Выберите читателя из списка" 
                                   Foreground="#2F4F4F" 
                                   TextWrapping="Wrap"
                                   LineHeight="25"/>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Кнопки -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,0">
                <Button Content="Отправить напоминание" Width="160" 
                        Style="{StaticResource ActionButtonStyle}" Click="SendReminder_Click" x:Name="SendButton" IsEnabled="False"/>
                <Button Content="Отмена" Width="100" Margin="10,0,0,0"
                        Style="{StaticResource CancelButtonStyle}" Click="Cancel_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>