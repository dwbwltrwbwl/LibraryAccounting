<Window x:Class="LibraryAccounting.Pages.ReaderSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Выбор читателя" Height="400" Width="400"
        WindowStartupLocation="CenterOwner"
        Background="#F4F1EC">

    <Border Background="#FFFDF9" BorderBrush="#C8BFAF" BorderThickness="1" CornerRadius="10" Margin="15">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Выберите читателя" FontSize="16" FontWeight="SemiBold" Foreground="#2F4F4F" Margin="0,0,0,15"/>

            <ListBox x:Name="ReadersListBox" Grid.Row="1" DisplayMemberPath="FullName" SelectedValuePath="ReaderId"
                     BorderBrush="#C8BFAF" BorderThickness="1" Background="#FFFDF9"
                     MouseDoubleClick="ReadersListBox_MouseDoubleClick"/>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                <Button Content="Отмена" Width="80" Click="Cancel_Click"/>
                <Button Content="Выбрать" Width="80" Margin="10,0,0,0" Style="{StaticResource ActionButtonStyle}" Click="Select_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>