<Window x:Class="LibraryAccounting.Windows.BookCopyAddWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Экземпляр книги"
        Height="650"
        Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F4F1EC">

    <Window.Resources>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2F4F4F"/>
            <Setter Property="BorderBrush" Value="#1F3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TextFieldStyle" TargetType="TextBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="#FFFDF9"/>
            <Setter Property="BorderBrush" Value="#C8BFAF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ReadOnlyTextFieldStyle" TargetType="TextBox" BasedOn="{StaticResource TextFieldStyle}">
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="Background" Value="#EDE8DF"/>
            <Setter Property="Foreground" Value="#6F6F6F"/>
        </Style>

        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="#FFFDF9"/>
            <Setter Property="BorderBrush" Value="#C8BFAF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="IsEditable" Value="True"/>
            <Setter Property="IsTextSearchEnabled" Value="False"/>
            <Setter Property="StaysOpenOnEdit" Value="True"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2F4F4F"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="InfoTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#2F4F4F"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>
    </Window.Resources>

    <Border Padding="20"
            Background="#FFFDF9"
            CornerRadius="10"
            BorderBrush="#C8BFAF"
            BorderThickness="1">

        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="550">
            <StackPanel>

                <TextBlock x:Name="TitleText"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#2F4F4F"
                           Margin="0,0,0,20"/>

                <!-- КНИГА -->
                <TextBlock Text="Книга*" Style="{StaticResource LabelStyle}"/>
                <ComboBox x:Name="BookBox"
                          Style="{StaticResource ComboBoxStyle}"
                          DisplayMemberPath="Title"
                          KeyUp="BookBox_KeyUp"
                          Margin="0,0,0,15"/>

                <!-- ИНВЕНТАРНЫЙ НОМЕР -->
                <TextBlock Text="Инвентарный номер*" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="InventoryBox"
                         Style="{StaticResource TextFieldStyle}"
                         TextChanged="InventoryBox_TextChanged"
                         PreviewTextInput="InventoryBox_PreviewTextInput"
                         Margin="0,0,0,15"/>

                <!-- СТЕЛЛАЖ -->
                <TextBlock Text="Стеллаж*" Style="{StaticResource LabelStyle}"/>
                <ComboBox x:Name="ShelfBox"
                          Style="{StaticResource ComboBoxStyle}"
                          IsEditable="True"
                          KeyUp="ShelfBox_KeyUp"
                          SelectionChanged="ShelfBox_SelectionChanged"
                          Margin="0,0,0,15"/>

                <!-- РЯД -->
                <TextBlock Text="Ряд*" Style="{StaticResource LabelStyle}"/>
                <ComboBox x:Name="RowBox"
                          Style="{StaticResource ComboBoxStyle}"
                          IsEditable="True"
                          KeyUp="RowBox_KeyUp"
                          SelectionChanged="RowBox_SelectionChanged"
                          IsEnabled="False"
                          Margin="0,0,0,15"/>

                <!-- ИНФОРМАЦИЯ О ЗАПОЛНЕННОСТИ ПОЛКИ -->
                <TextBlock x:Name="ShelfInfoText" 
                           Style="{StaticResource InfoTextStyle}"
                           Visibility="Collapsed"
                           TextWrapping="Wrap"/>

                <!-- ДАТА ДОБАВЛЕНИЯ (только для просмотра при редактировании) -->
                <TextBlock x:Name="AddedDateLabel" 
                           Text="Дата добавления" 
                           Style="{StaticResource LabelStyle}"
                           Visibility="Collapsed"
                           Margin="0,0,0,0"/>
                <TextBox x:Name="AddedDateBox"
                         Style="{StaticResource ReadOnlyTextFieldStyle}"
                         Visibility="Collapsed"
                         Margin="0,0,0,15"/>

                <!-- ПОСЛЕДНИЙ ЧИТАТЕЛЬ (только для просмотра при редактировании) -->
                <TextBlock x:Name="LastReaderLabel" 
                           Text="Последний читатель" 
                           Style="{StaticResource LabelStyle}"
                           Visibility="Collapsed"
                           Margin="0,0,0,0"/>
                <TextBox x:Name="LastReaderBox"
                         Style="{StaticResource ReadOnlyTextFieldStyle}"
                         Visibility="Collapsed"
                         Margin="0,0,0,15"/>

                <!-- ПОСЛЕДНЯЯ ВЫДАЧА (только для просмотра при редактировании) -->
                <TextBlock x:Name="LastLoanDateLabel" 
                           Text="Последняя выдача" 
                           Style="{StaticResource LabelStyle}"
                           Visibility="Collapsed"
                           Margin="0,0,0,0"/>
                <TextBox x:Name="LastLoanDateBox"
                         Style="{StaticResource ReadOnlyTextFieldStyle}"
                         Visibility="Collapsed"
                         Margin="0,0,0,15"/>

                <!-- ВСЕГО ВЫДАЧ (только для просмотра при редактировании) -->
                <TextBlock x:Name="TotalLoansLabel" 
                           Text="Всего выдач" 
                           Style="{StaticResource LabelStyle}"
                           Visibility="Collapsed"
                           Margin="0,0,0,0"/>
                <TextBox x:Name="TotalLoansBox"
                         Style="{StaticResource ReadOnlyTextFieldStyle}"
                         Visibility="Collapsed"
                         Margin="0,0,0,15"/>

                <!-- СТАТУС (только для редактирования) -->
                <TextBlock x:Name="StatusLabel" 
                           Text="Статус" 
                           Style="{StaticResource LabelStyle}"
                           Visibility="Collapsed"
                           Margin="0,0,0,0"/>
                <ComboBox x:Name="StatusBox"
                          Style="{StaticResource ComboBoxStyle}"
                          Visibility="Collapsed"
                          Margin="0,0,0,15">
                    <ComboBoxItem Content="Доступна"/>
                    <ComboBoxItem Content="Выдана"/>
                    <ComboBoxItem Content="Потеряна"/>
                    <ComboBoxItem Content="Списана"/>
                </ComboBox>

                <!-- КНОПКИ -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,20,0,0">

                    <Button Content="Отмена"
                            Width="90"
                            Margin="0,0,10,0"
                            Click="Cancel_Click"/>

                    <Button Content="Сохранить"
                            Width="110"
                            Style="{StaticResource ActionButtonStyle}"
                            Click="Save_Click"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>