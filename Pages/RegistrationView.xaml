<Page x:Class="LibraryAccounting.Pages.RegistrationView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d"
      d:DesignHeight="750"
      d:DesignWidth="900"
      Background="#F4F1EC"
      ScrollViewer.VerticalScrollBarVisibility="Auto">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid>
            <Border Width="700"
                    Padding="35"
                    Background="#FFFDF9"
                    CornerRadius="12"
                    BorderBrush="#C8BFAF"
                    BorderThickness="1"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Center"
                    Margin="0,20">

                <StackPanel>

                    <!-- Заголовок -->
                    <TextBlock Text="Регистрация сотрудника"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="#2F4F4F"
                               Margin="0,0,0,8"
                               HorizontalAlignment="Center"/>

                    <TextBlock Text="Заполните данные для создания учетной записи"
                               FontSize="13"
                               Foreground="#6F6F6F"
                               Margin="0,0,0,20"
                               HorizontalAlignment="Center"/>

                    <!-- Фото профиля -->
                    <StackPanel Margin="0,0,0,20" HorizontalAlignment="Center">
                        <Border Width="100" Height="100" 
                                CornerRadius="5" 
                                Background="#F4F1EC"
                                BorderBrush="#C8BFAF"
                                BorderThickness="2">
                            <Image x:Name="ProfileImage" 
                                   Width="96" Height="96"
                                   Stretch="UniformToFill"
                                   Source="/Images/default-avatar.png"/>
                        </Border>
                        <Button x:Name="UploadPhotoBtn"
                                Content="Загрузить фото"
                                Margin="0,8,0,0"
                                Background="#E8E4DC"
                                BorderThickness="0"
                                Padding="12,5"
                                FontSize="11"
                                Cursor="Hand"
                                Click="UploadPhoto_Click"/>
                    </StackPanel>

                    <!-- Основные данные (2 колонки) -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Левая колонка -->
                        <StackPanel Grid.Column="0">
                            <!-- Фамилия -->
                            <TextBlock Text="Фамилия"
                                       FontWeight="SemiBold"
                                       Foreground="#3A3A3A"/>
                            <Border Margin="0,6,0,16"
                                    Background="#F4F1EC"
                                    BorderBrush="#C8BFAF"
                                    BorderThickness="1"
                                    CornerRadius="5">
                                <TextBox x:Name="LastNameTextBox"
                                         Height="36"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Padding="10" 
                                         MaxLength="50"
                                         TextChanged="NameTextBox_TextChanged"/>
                            </Border>

                            <!-- Имя -->
                            <TextBlock Text="Имя"
                                       FontWeight="SemiBold"
                                       Foreground="#3A3A3A"/>
                            <Border Margin="0,6,0,16"
                                    Background="#F4F1EC"
                                    BorderBrush="#C8BFAF"
                                    BorderThickness="1"
                                    CornerRadius="5">
                                <TextBox x:Name="FirstNameTextBox"
                                         Height="36"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Padding="10" 
                                         MaxLength="50"
                                         TextChanged="NameTextBox_TextChanged"/>
                            </Border>

                            <!-- Отчество -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="Отчество"
                                           FontWeight="SemiBold"
                                           Foreground="#3A3A3A"/>
                                <TextBlock Text=" (необязательно)"
                                           FontSize="11"
                                           Foreground="#6F6F6F"
                                           VerticalAlignment="Bottom"/>
                            </StackPanel>
                            <Border Margin="0,6,0,16"
                                    Background="#F4F1EC"
                                    BorderBrush="#C8BFAF"
                                    BorderThickness="1"
                                    CornerRadius="5">
                                <TextBox x:Name="MiddleNameTextBox"
                                         Height="36"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Padding="10" 
                                         MaxLength="50"
                                         TextChanged="NameTextBox_TextChanged"/>
                            </Border>

                            <!-- Дата рождения -->
                            <TextBlock Text="Дата рождения"
                                       FontWeight="SemiBold"
                                       Foreground="#3A3A3A"/>
                            <Border Margin="0,6,0,16"
                                    Background="#F4F1EC"
                                    BorderBrush="#C8BFAF"
                                    BorderThickness="1"
                                    CornerRadius="5">
                                <DatePicker x:Name="BirthDatePicker"
                                            Height="36"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            SelectedDateChanged="BirthDatePicker_SelectedDateChanged"/>
                            </Border>
                        </StackPanel>

                        <!-- Правая колонка -->
                        <StackPanel Grid.Column="2">
                            <!-- Логин -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                                <TextBlock Text="Логин"
                                           FontWeight="SemiBold"
                                           Foreground="#3A3A3A"/>
                                <TextBlock Text=" (только латиница, цифры, _ и .)"
                                           FontSize="10"
                                           Foreground="#999"
                                           VerticalAlignment="Bottom"/>
                            </StackPanel>
                            <Border Margin="0,6,0,16"
                                    Background="#F4F1EC"
                                    BorderBrush="#C8BFAF"
                                    BorderThickness="1"
                                    CornerRadius="5">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="LoginTextBox" 
                                             Height="36"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Padding="10" 
                                             MaxLength="50"
                                             TextChanged="LoginTextBox_TextChanged"/>
                                    <TextBlock x:Name="LoginStatusIndicator"
                                               Grid.Column="1"
                                               Width="20"
                                               Height="20"
                                               Margin="0,0,10,0"
                                               VerticalAlignment="Center"
                                               TextAlignment="Center"
                                               FontSize="14"/>
                                </Grid>
                            </Border>

                            <!-- Email с маской и подсказкой -->
                            <TextBlock Text="Email"
           FontWeight="SemiBold"
           Foreground="#3A3A3A"
           Margin="0,0,0,0"/>
                            <Border Margin="0,6,0,16"
        Background="#F4F1EC"
        BorderBrush="#C8BFAF"
        BorderThickness="1"
        CornerRadius="5">
                                <Grid>
                                    <TextBox x:Name="EmailTextBox"
                 Height="36"
                 Background="Transparent"
                 BorderThickness="0"
                 Padding="10" 
                 FontSize="14"
                 MaxLength="100"
                 TextChanged="EmailTextBox_TextChanged"/>
                                    <TextBlock x:Name="EmailPlaceholder"
                   Text="example@mail.ru"
                   IsHitTestVisible="False"
                   VerticalAlignment="Center"
                   Margin="10,0,0,0"
                   Foreground="LightGray"
                   FontSize="14"
                   FontFamily="{Binding ElementName=EmailTextBox, Path=FontFamily}"/>
                                </Grid>
                            </Border>

                            <!-- Телефон с маской и подсказкой -->
                            <TextBlock Text="Телефон"
           FontWeight="SemiBold"
           Foreground="#3A3A3A"
           Margin="0,0,0,5"/>
                            <Border Margin="0,6,0,16"
        Background="#F4F1EC"
        BorderBrush="#C8BFAF"
        BorderThickness="1"
        CornerRadius="5">
                                <Grid>
                                    <TextBox x:Name="PhoneTextBox"
                 Height="36"
                 Background="Transparent"
                 BorderThickness="0"
                 Padding="10" 
                 FontSize="14"
                 MaxLength="16"
                 TextChanged="PhoneTextBox_TextChanged"/>
                                    <TextBlock x:Name="PhonePlaceholder"
                   Text="+7(999)999-99-99"
                   IsHitTestVisible="False"
                   VerticalAlignment="Center"
                   Margin="10,0,0,0"
                   Foreground="LightGray"
                   FontSize="14"
                   FontFamily="{Binding ElementName=PhoneTextBox, Path=FontFamily}"/>
                                </Grid>
                            </Border>

                            <!-- Стаж -->
                            <TextBlock Text="Стаж (лет)"
                                       FontWeight="SemiBold"
                                       Foreground="#3A3A3A"/>
                            <Border Margin="0,6,0,16"
                                    Background="#F4F1EC"
                                    BorderBrush="#C8BFAF"
                                    BorderThickness="1"
                                    CornerRadius="5">
                                <TextBox x:Name="ExperienceTextBox"
                                         Height="36"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Padding="10" 
                                         MaxLength="3"
                                         TextChanged="ExperienceTextBox_TextChanged"/>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- Пароль (на всю ширину) -->
                    <TextBlock Text="Пароль"
                               FontWeight="SemiBold"
                               Foreground="#3A3A3A"/>
                    <TextBlock Text="(мин. 6 символов, буквы разного регистра, цифры)"
                               FontSize="10"
                               Foreground="#999"
                               Margin="0,2,0,5"/>
                    <Border Margin="0,6,0,16"
                            Background="#F4F1EC"
                            BorderBrush="#C8BFAF"
                            BorderThickness="1"
                            CornerRadius="5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <PasswordBox x:Name="PasswordBox" 
                                         Height="36"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Padding="10" 
                                         MaxLength="256"
                                         PasswordChanged="PasswordBox_PasswordChanged"/>
                            <Button x:Name="TogglePasswordBtn"
                                    Grid.Column="1"
                                    Content="👁️"
                                    Width="30"
                                    Height="30"
                                    Margin="0,0,5,0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    FontSize="14"
                                    Click="TogglePassword_Click"/>
                        </Grid>
                    </Border>

                    <!-- Индикатор сложности пароля -->
                    <Border x:Name="PasswordStrengthBorder"
                            Background="#F4F1EC"
                            CornerRadius="5"
                            Padding="10,5"
                            Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Сложность пароля:"
                                       Foreground="#2F4F4F"
                                       FontSize="11"
                                       Margin="0,0,10,0"/>
                            <TextBlock x:Name="PasswordStrengthText"
                                       Grid.Column="1"
                                       Text=""
                                       FontSize="11"
                                       FontWeight="SemiBold"/>
                        </Grid>
                    </Border>

                    <!-- Подтверждение пароля -->
                    <TextBlock Text="Подтвердите пароль"
                               FontWeight="SemiBold"
                               Foreground="#3A3A3A"/>
                    <Border Margin="0,6,0,24"
                            Background="#F4F1EC"
                            BorderBrush="#C8BFAF"
                            BorderThickness="1"
                            CornerRadius="5">
                        <PasswordBox x:Name="ConfirmPasswordBox" 
                                     Height="36"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="10" 
                                     MaxLength="256"
                                     PasswordChanged="ConfirmPasswordBox_PasswordChanged"/>
                    </Border>

                    <!-- Кнопка регистрации -->
                    <Border Height="40"
                            CornerRadius="8"
                            Background="#2F4F4F">
                        <Button x:Name="RegisterBtn"
                                Click="RegisterButton_Click"
                                Content="Зарегистрироваться"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Background="Transparent"
                                Foreground="White"
                                BorderThickness="0"
                                Cursor="Hand"/>
                    </Border>

                    <!-- Возврат к авторизации -->
                    <Button Click="BackButton_Click" 
                            Content="Назад к авторизации"
                            Margin="0,12,0,0"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="#2F4F4F"
                            FontSize="13"
                            Cursor="Hand"
                            HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>