<Window x:Class="LibraryAccounting.Windows.BookAnalyticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        Title="Аналитика книжного фонда" Height="700" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="#F4F1EC">

    <Window.Resources>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2F4F4F"/>
            <Setter Property="BorderBrush" Value="#1F3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Text="Аналитика книжного фонда" FontSize="22" FontWeight="SemiBold" Foreground="#2F4F4F" Margin="0,0,0,15"/>

        <!-- Кнопки типов аналитики -->
        <WrapPanel Grid.Row="1" Margin="0,0,0,15">
            <Button Content="По жанрам" Width="120" Margin="0,0,10,0" Style="{StaticResource ActionButtonStyle}" Click="ByGenre_Click"/>
            <Button Content="По годам" Width="120" Margin="0,0,10,0" Style="{StaticResource ActionButtonStyle}" Click="ByYear_Click"/>
            <Button Content="По языкам" Width="120" Margin="0,0,10,0" Style="{StaticResource ActionButtonStyle}" Click="ByLanguage_Click"/>
            <Button Content="По издательствам" Width="150" Margin="0,0,10,0" Style="{StaticResource ActionButtonStyle}" Click="ByPublisher_Click"/>
            <Button Content="Топ популярных" Width="130" Margin="0,0,10,0" Style="{StaticResource ActionButtonStyle}" Click="TopPopular_Click"/>
            <Button Content="Новые поступления" Width="140" Style="{StaticResource ActionButtonStyle}" Click="NewArrivals_Click"/>
        </WrapPanel>

        <!-- График -->
        <Border Grid.Row="2" Background="#FFFDF9" BorderBrush="#C8BFAF" BorderThickness="1" CornerRadius="8" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="ChartTitle" Text="Выберите тип аналитики" FontSize="16" FontWeight="SemiBold" Foreground="#2F4F4F" Margin="0,0,0,15"/>

                <lvc:CartesianChart x:Name="BarChart" Grid.Row="1" LegendLocation="Top"/>
                <lvc:PieChart x:Name="PieChart" Grid.Row="1" LegendLocation="Right"/>
                <lvc:CartesianChart x:Name="LineChart" Grid.Row="1" LegendLocation="Top"/>

                <TextBlock x:Name="NoDataText" Grid.Row="1" Text="Нет данных для отображения" 
                           FontSize="14" Foreground="#6F6F6F" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                    <Button Content="Экспорт" Width="100" Style="{StaticResource ActionButtonStyle}" Click="Export_Click"/>
                    <Button Content="Закрыть" Width="100" Margin="10,0,0,0" Click="Close_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>