<Page x:Class="LibraryAccounting.Pages.ReportsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
      mc:Ignorable="d"
      d:DesignHeight="700"
      d:DesignWidth="1200"
      Background="#F4F1EC"
      Title="ReportsView">

    <Page.Resources>
        <!-- Стиль для кнопок -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2F4F4F"/>
            <Setter Property="BorderBrush" Value="#1F3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1F3A3A"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#0F2A2A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для выделенной кнопки (Создать отчет) -->
        <Style x:Key="HighlightButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#2F6F6F"/>
            <Setter Property="BorderBrush" Value="#1F5F5F"/>
            <Setter Property="Padding" Value="20,0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1F5F5F"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для кнопок удаления -->
        <Style x:Key="DeleteButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#5F3E40"/>
            <Setter Property="BorderBrush" Value="#4A2F30"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4A2F30"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для второстепенных кнопок -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#FFFDF9"/>
            <Setter Property="Foreground" Value="#2F4F4F"/>
            <Setter Property="BorderBrush" Value="#C8BFAF"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F4F1EC"/>
                    <Setter Property="BorderBrush" Value="#2F4F4F"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для DataGrid -->
        <Style x:Key="BooksDataGridStyle" TargetType="DataGrid">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#D4CFC8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#FFFDF9"/>
            <Setter Property="RowBackground" Value="#FFFDF9"/>
            <Setter Property="AlternatingRowBackground" Value="#F9F8F6"/>
            <Setter Property="VerticalGridLinesBrush" Value="#E8E4DD"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E8E4DD"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
        </Style>

        <!-- Стиль для заголовков колонок -->
        <Style x:Key="BooksDataGridColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Height" Value="45"/>
            <Setter Property="Background" Value="#2F4F4F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderBrush" Value="#1F3A3A"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
        </Style>

        <!-- Стиль для строк -->
        <Style x:Key="BooksDataGridRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="#FFFDF9"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#D4E8E8"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0EDE8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для ячеек -->
        <Style x:Key="BooksDataGridCellStyle" TargetType="DataGridCell">
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#E8E4DD"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#D4E8E8"/>
                    <Setter Property="Foreground" Value="#1F3A3A"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок страницы -->
        <Border Grid.Row="0" 
                Background="#FFFDF9" 
                BorderBrush="#C8BFAF" 
                BorderThickness="1" 
                CornerRadius="10" 
                Padding="20" 
                Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Отчёты"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="#2F4F4F"/>
                <TextBlock Text="Аналитика и контроль работы библиотеки"
                           FontSize="13"
                           Foreground="#6F6F6F"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Панель параметров -->
        <Border Grid.Row="1" 
                Background="#FFFDF9" 
                BorderBrush="#C8BFAF" 
                BorderThickness="1" 
                CornerRadius="10" 
                Padding="15" 
                Margin="0,0,0,20">
            <StackPanel>
                <!-- Строка 1: Поиск, сортировка, период -->
                <WrapPanel Margin="0,0,0,15">
                    <Border Background="#F4F1EC" CornerRadius="6" Padding="10,5" Margin="0,0,15,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Поиск:" VerticalAlignment="Center" 
                                       Foreground="#2F4F4F" FontWeight="SemiBold" Margin="0,0,10,0"/>
                            <TextBox x:Name="SearchBox" Width="200" Height="30"
                                     TextChanged="SearchBox_TextChanged"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#F4F1EC" CornerRadius="6" Padding="10,5" Margin="0,0,15,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Сортировка:" VerticalAlignment="Center" 
                                       Foreground="#2F4F4F" FontWeight="SemiBold" Margin="0,0,10,0"/>
                            <ComboBox x:Name="SortByCombo" Width="150" Height="30" 
                                      SelectionChanged="SortByCombo_SelectionChanged">
                                <ComboBoxItem Content="По умолчанию"/>
                                <ComboBoxItem Content="По названию (А-Я)"/>
                                <ComboBoxItem Content="По названию (Я-А)"/>
                                <ComboBoxItem Content="По дате (сначала новые)"/>
                                <ComboBoxItem Content="По дате (сначала старые)"/>
                                <ComboBoxItem Content="По количеству (убыв.)"/>
                                <ComboBoxItem Content="По количеству (возр.)"/>
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <Border Background="#F4F1EC" CornerRadius="6" Padding="10,5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Период:" VerticalAlignment="Center" 
                                       Foreground="#2F4F4F" FontWeight="SemiBold" Margin="0,0,10,0"/>
                            <DatePicker x:Name="DateFrom" Width="110" Height="30"/>
                            <TextBlock Text="—" VerticalAlignment="Center" Margin="8,0"/>
                            <DatePicker x:Name="DateTo" Width="110" Height="30"/>
                            <Button x:Name="ApplyFilterBtn" 
                                    Content="Применить" 
                                    Width="80" 
                                    Height="30" 
                                    Margin="10,0,0,0"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="ApplyFilter_Click"/>
                            <Button x:Name="ResetFilterBtn" 
                                    Content="Сбросить" 
                                    Width="80" 
                                    Height="30" 
                                    Margin="5,0,0,0"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="ResetFilter_Click"/>
                        </StackPanel>
                    </Border>
                </WrapPanel>

                <!-- Строка 2: Быстрые фильтры и экспорт -->
                <WrapPanel>
                    <Border Background="#F4F1EC" CornerRadius="6" Padding="10,5" Margin="0,0,15,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Быстрые фильтры:" VerticalAlignment="Center" 
                                       Foreground="#2F4F4F" FontWeight="SemiBold" Margin="0,0,10,0"/>
                            <Button Content="Сегодня" Width="70" Height="30" Margin="0,0,5,0"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="QuickFilterToday_Click"/>
                            <Button Content="Неделя" Width="70" Height="30" Margin="0,0,5,0"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="QuickFilterWeek_Click"/>
                            <Button Content="Месяц" Width="70" Height="30" Margin="0,0,5,0"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="QuickFilterMonth_Click"/>
                            <Button Content="Квартал" Width="70" Height="30"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="QuickFilterQuarter_Click"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#F4F1EC" CornerRadius="6" Padding="10,5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Экспорт:" VerticalAlignment="Center" 
                                       Foreground="#2F4F4F" FontWeight="SemiBold" Margin="0,0,10,0"/>
                            <Button x:Name="ExportCSVBtn" 
                                    Content="CSV" 
                                    Width="70" Height="30"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Click="ExportToCSV_Click"/>
                        </StackPanel>
                    </Border>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- Кнопки отчетов -->
        <WrapPanel Grid.Row="2" Margin="0,0,0,15">
            <Button x:Name="IssuedBooksBtn" 
                    Content="Выданные книги" 
                    Width="140" Height="35" Margin="0,0,10,0"
                    Style="{StaticResource ActionButtonStyle}"
                    Click="IssuedBooks_Click"/>

            <Button x:Name="OverdueBtn" 
                    Content="Просрочки" 
                    Width="120" Height="35" Margin="0,0,10,0"
                    Style="{StaticResource ActionButtonStyle}"
                    Click="Overdue_Click"/>

            <Button x:Name="PopularBooksBtn" 
                    Content="Популярные книги" 
                    Width="150" Height="35" Margin="0,0,10,0"
                    Style="{StaticResource ActionButtonStyle}"
                    Click="PopularBooks_Click"/>

            <Button x:Name="ActiveReadersBtn" 
                    Content="Активные читатели" 
                    Width="150" Height="35" Margin="0,0,10,0"
                    Style="{StaticResource ActionButtonStyle}"
                    Click="ActiveReaders_Click"/>

            <Button x:Name="GenreStatsBtn" 
                    Content="По жанрам" 
                    Width="120" Height="35" Margin="0,0,10,0"
                    Style="{StaticResource ActionButtonStyle}"
                    Click="GenreStats_Click"/>

            <!-- Выделенная кнопка Создать отчет -->
            <Button x:Name="CustomReportBtn" 
                    Content="Создать отчет" 
                    Width="150" Height="35" Margin="10,0,0,0"
                    Style="{StaticResource HighlightButtonStyle}"
                    Click="CustomReport_Click"/>
        </WrapPanel>

        <!-- Заголовок текущего отчета -->
        <Border Grid.Row="3" 
                Background="#F4F1EC" 
                CornerRadius="6" 
                Padding="12,8" 
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="CurrentReportTitle" 
                               Text="Выберите отчет из списка выше"
                               FontSize="14" 
                               FontWeight="SemiBold" 
                               Foreground="#2F4F4F"/>
                    <TextBlock x:Name="RecordsCount" 
                               Text="" 
                               FontSize="12" 
                               Foreground="#6F6F6F" 
                               Margin="12,0,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="SwitchViewBtn" 
                            Content="📊 График" 
                            Width="100" Height="25"
                            Margin="0,0,10,0"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="SwitchView_Click"
                            Visibility="Collapsed"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- DataGrid -->
        <DataGrid x:Name="ReportsDataGrid" 
                  Grid.Row="3"
                  Margin="0,50,0,0"
                  AutoGenerateColumns="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  Style="{StaticResource BooksDataGridStyle}"
                  ColumnHeaderStyle="{StaticResource BooksDataGridColumnHeaderStyle}"
                  RowStyle="{StaticResource BooksDataGridRowStyle}"
                  CellStyle="{StaticResource BooksDataGridCellStyle}"/>

        <!-- Chart View -->
        <Border x:Name="ChartViewPanel" 
                Grid.Row="3"
                Margin="0,50,0,0"
                Background="#FFFDF9" 
                BorderBrush="#C8BFAF" 
                BorderThickness="1" 
                CornerRadius="10" 
                Padding="15"
                Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <lvc:CartesianChart x:Name="BarChart" 
                                    Visibility="Collapsed"
                                    LegendLocation="Top"/>
                <lvc:PieChart x:Name="PieChart" 
                              Visibility="Collapsed"
                              LegendLocation="Right"/>
                <lvc:CartesianChart x:Name="LineChart" 
                                    Visibility="Collapsed"
                                    LegendLocation="Top"/>

                <TextBlock x:Name="ChartMessage" 
                           Grid.Row="1" 
                           Text=""
                           TextWrapping="Wrap"
                           Foreground="#6F6F6F"
                           FontSize="12"
                           Margin="0,10,0,0"
                           HorizontalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Панель создания отчета (изначально скрыта) -->
        <Border x:Name="CustomReportPanel" 
        Grid.Row="3"
        Background="#FFFDF9" 
        BorderBrush="#C8BFAF" 
        BorderThickness="1" 
        CornerRadius="10" 
        Padding="15"
        Margin="0,50,0,0"
        Visibility="Collapsed">
            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="450">
                <StackPanel Margin="0">
                    <TextBlock Text="Конструктор отчетов" FontSize="16" 
                       FontWeight="Bold" Foreground="#2F4F4F" Margin="0,0,0,15"/>

                    <!-- Выбор типа отчета -->
                    <Border Background="#F4F1EC" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Тип отчета:" VerticalAlignment="Center" 
                               Foreground="#2F4F4F" FontWeight="SemiBold" Margin="0,0,15,0"/>
                            <ComboBox x:Name="ReportTypeCombo" Grid.Column="1" Width="200" Height="28"
                              SelectionChanged="ReportTypeCombo_SelectionChanged">
                                <ComboBoxItem Content="Выдача книг" IsSelected="True"/>
                                <ComboBoxItem Content="Читатели"/>
                                <ComboBoxItem Content="Книжный фонд"/>
                            </ComboBox>
                        </Grid>
                    </Border>

                    <!-- Выбор полей -->
                    <Border Background="#F4F1EC" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Поля для отображения:" 
                               Foreground="#2F4F4F" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <ListBox x:Name="FieldsListBox" Grid.Row="1" Height="120" 
                             SelectionMode="Multiple"
                             BorderBrush="#C8BFAF" BorderThickness="1">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}"
                                          Margin="5,2"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                    <!-- Блок с лимитом -->
                    <Border Background="#F4F1EC" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Лимит записей:" VerticalAlignment="Center" 
                   Foreground="#2F4F4F" FontWeight="SemiBold" Margin="0,0,10,0"/>
                            <TextBox x:Name="LimitInput" Grid.Column="1" Text="100" Width="80" Height="28" 
                 TextAlignment="Center" HorizontalAlignment="Left" MaxLength="3"/>
                        </Grid>
                    </Border>

                    <!-- Кнопки -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5,0,0">
                        <Button Content="Предпросмотр" Width="100" Height="32" Margin="0,0,8,0"
                        Style="{StaticResource ActionButtonStyle}"
                        Click="PreviewCustomReport_Click"/>
                        <Button Content="Экспорт" Width="80" Height="32" Margin="0,0,8,0"
                        Style="{StaticResource ActionButtonStyle}"
                        Click="ExportCustomReport_Click"/>
                        <Button Content="Закрыть" Width="80" Height="32"
                        Style="{StaticResource DeleteButtonStyle}"
                        Click="CloseCustomReport_Click"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Индикатор загрузки -->
        <StackPanel x:Name="LoadingPanel" 
                    Grid.Row="3" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center"
                    Visibility="Collapsed">
            <Border Background="White" CornerRadius="8" Padding="20" Opacity="0.9">
                <StackPanel>
                    <TextBlock Text="Загрузка..." Margin="0,10,0,0" Foreground="#2F4F4F"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Нижняя панель с итогами -->
        <Border x:Name="BottomPanel" 
                Grid.Row="4" 
                Background="#FFFDF9" 
                BorderBrush="#C8BFAF" 
                BorderThickness="1" 
                CornerRadius="10" 
                Padding="15" 
                Margin="0,20,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Итого:" 
                               Foreground="#2F4F4F" 
                               FontWeight="SemiBold" 
                               Margin="0,0,15,0"/>
                    <TextBlock x:Name="SummaryText" 
                               Text="" 
                               Foreground="#6F6F6F"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="BackToConstructorBtn" 
                            Content="Назад к конструктору" 
                            Width="140" Height="30"
                            Margin="0,0,10,0"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Visibility="Collapsed"
                            Click="BackToConstructor_Click"/>
                    <Button x:Name="CopyBtn" 
                            Content="Копировать" 
                            Width="100" Height="30"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="CopyToClipboard_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>