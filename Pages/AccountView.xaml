<Page x:Class="LibraryAccounting.Pages.AccountView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:conv="clr-namespace:LibraryAccounting.Converters"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Background="#F4F1EC"
      d:DesignHeight="700"
      d:DesignWidth="1000">

    <Page.Resources>
        <conv:ByteArrayToImageConverter x:Key="ByteArrayToImageConverter"/>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#6F6F6F"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Foreground" Value="#2F4F4F"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <Style x:Key="TextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Background" Value="#F4F1EC"/>
            <Setter Property="BorderBrush" Value="#C8BFAF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,4,0,15"/>
        </Style>

        <Style x:Key="ReadOnlyTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource TextBoxStyle}">
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="Background" Value="#EDE8DF"/>
            <Setter Property="Foreground" Value="#6F6F6F"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="#FFFDF9"
                BorderBrush="#C8BFAF"
                BorderThickness="1"
                CornerRadius="10"
                Padding="20"
                Margin="0,0,0,20">

            <StackPanel>
                <TextBlock Text="Аккаунт пользователя"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="#2F4F4F"/>

                <TextBlock Text="Информация о текущей учетной записи"
                           FontSize="13"
                           Foreground="#6F6F6F"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Border Background="#FFFDF9"
                    BorderBrush="#C8BFAF"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="30"
                    Width="900"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="0,0,0,20">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Левая колонка - фото -->
                    <StackPanel HorizontalAlignment="Center">
                        <Border Width="150"
                                Height="200"
                                CornerRadius="10"
                                BorderBrush="#C8BFAF"
                                BorderThickness="1"
                                Background="#F4F1EC"
                                Padding="6">
                            <Image x:Name="UserPhoto"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Border>

                        <Button Content="Загрузить фото"
                                Style="{StaticResource ActionButtonStyle}"
                                Margin="0,15,0,0"
                                Width="160"
                                Click="LoadPhoto_Click"/>

                        <Button Content="Удалить фото"
                                Style="{StaticResource ActionButtonStyle}"
                                Background="#5F3E40"
                                Margin="0,10,0,0"
                                Width="160"
                                Click="RemovePhoto_Click"/>
                    </StackPanel>

                    <!-- Правая колонка - информация -->
                    <ScrollViewer Grid.Column="1" Margin="30,0,0,0" VerticalScrollBarVisibility="Auto" MaxHeight="550">
                        <StackPanel>
                            <!-- Личная информация -->
                            <TextBlock Text="Личная информация" 
                                       FontSize="16" 
                                       FontWeight="Bold" 
                                       Foreground="#2F4F4F"
                                       Margin="0,0,0,15"/>

                            <TextBlock Text="Фамилия" Style="{StaticResource LabelStyle}"/>
                            <TextBox x:Name="LastNameBox" 
                                     Style="{StaticResource TextBoxStyle}" 
                                     MaxLength="50"
                                     PreviewTextInput="NameOnly_PreviewTextInput"/>

                            <TextBlock Text="Имя" Style="{StaticResource LabelStyle}"/>
                            <TextBox x:Name="FirstNameBox" 
                                     Style="{StaticResource TextBoxStyle}" 
                                     MaxLength="50"
                                     PreviewTextInput="NameOnly_PreviewTextInput"/>

                            <TextBlock Text="Отчество" Style="{StaticResource LabelStyle}"/>
                            <TextBox x:Name="MiddleNameBox" 
                                     Style="{StaticResource TextBoxStyle}" 
                                     MaxLength="50"
                                     PreviewTextInput="NameOnly_PreviewTextInput"/>

                            <TextBlock Text="Дата рождения" Style="{StaticResource LabelStyle}"/>
                            <DatePicker x:Name="BirthDatePicker" 
                                        Height="34"
                                        Background="#F4F1EC"
                                        BorderBrush="#C8BFAF"
                                        BorderThickness="1"
                                        Margin="0,4,0,15"/>

                            <!-- Контактная информация -->
                            <TextBlock Text="Контактная информация" 
                                       FontSize="16" 
                                       FontWeight="Bold" 
                                       Foreground="#2F4F4F"
                                       Margin="0,15,0,15"/>

                            <TextBlock Text="Email" Style="{StaticResource LabelStyle}"/>
                            <TextBox x:Name="EmailBox" 
                                     Style="{StaticResource TextBoxStyle}" 
                                     MaxLength="100"/>

                            <TextBlock Text="Телефон" Style="{StaticResource LabelStyle}"/>
                            <TextBox x:Name="PhoneBox" 
         Style="{StaticResource TextBoxStyle}" 
         MaxLength="20"
         PreviewTextInput="PhoneOnly_PreviewTextInput"
         TextChanged="PhoneBox_TextChanged"/>

                            <!-- Информация об аккаунте -->
                            <TextBlock Text="Информация об аккаунте" 
                                       FontSize="16" 
                                       FontWeight="Bold" 
                                       Foreground="#2F4F4F"
                                       Margin="0,15,0,15"/>

                            <TextBlock Text="Логин" Style="{StaticResource LabelStyle}"/>
                            <TextBox x:Name="LoginBox" 
                                     Style="{StaticResource TextBoxStyle}" 
                                     MaxLength="50"/>

                            <TextBlock Text="Роль" Style="{StaticResource LabelStyle}"/>
                            <TextBlock x:Name="RoleText" Style="{StaticResource ValueStyle}"/>

                            <TextBlock Text="Стаж работы (лет)" Style="{StaticResource LabelStyle}"/>
                            <TextBox x:Name="ExperienceBox" 
                                     Style="{StaticResource TextBoxStyle}"
                                     PreviewTextInput="NumberOnly_PreviewTextInput" 
                                     MaxLength="10"/>

                            <TextBlock Text="Дата регистрации" Style="{StaticResource LabelStyle}"/>
                            <TextBox x:Name="RegistrationDateBox" Style="{StaticResource ReadOnlyTextBoxStyle}"/>

                            <TextBlock Text="Последний вход" Style="{StaticResource LabelStyle}"/>
                            <TextBox x:Name="LastLoginDateBox" Style="{StaticResource ReadOnlyTextBoxStyle}"/>

                            <TextBlock Text="Статус" Style="{StaticResource LabelStyle}"/>
                            <TextBlock x:Name="StatusText" Style="{StaticResource ValueStyle}"/>

                            <!-- Кнопки -->
                            <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                                <Button Content="Сохранить изменения"
                                        Width="160"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Click="SaveProfile_Click"/>

                                <Button Content="Сменить пароль"
                                        Width="160"
                                        Margin="15,0,0,0"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Click="ChangePassword_Click"/>

                                <Button Content="Выйти из аккаунта"
                                        Width="160"
                                        Margin="15,0,0,0"
                                        Background="#5F3E40"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Click="Logout_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </ScrollViewer>
    </Grid>
</Page>