<Window x:Class="LibraryAccounting.Pages.BookEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Книга"
        Height="800"
        Width="950"
        WindowStartupLocation="CenterOwner"
        Background="#F4F1EC">

    <Window.Resources>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2F4F4F"/>
            <Setter Property="BorderBrush" Value="#1F3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1F3A3A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SmallButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Width" Value="35"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#5F3E40"/>
            <Setter Property="Height" Value="30"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2F4F4F"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="SubLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource LabelStyle}">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Foreground" Value="#666"/>
            <Setter Property="Margin" Value="0,2,0,5"/>
        </Style>

        <Style x:Key="TextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="#FFFDF9"/>
            <Setter Property="BorderBrush" Value="#C8BFAF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="MultiLineTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource TextBoxStyle}">
            <Setter Property="Height" Value="80"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="VerticalContentAlignment" Value="Top"/>
        </Style>

        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="#FFFDF9"/>
            <Setter Property="BorderBrush" Value="#C8BFAF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="IsEditable" Value="True"/>
            <Setter Property="IsTextSearchEnabled" Value="False"/>
            <Setter Property="StaysOpenOnEdit" Value="True"/>
        </Style>

        <Style x:Key="ListBoxStyle" TargetType="ListBox">
            <Setter Property="Height" Value="100"/>
            <Setter Property="Background" Value="#FFFDF9"/>
            <Setter Property="BorderBrush" Value="#C8BFAF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="SelectionMode" Value="Extended"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Height" Value="28"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Border Background="#FFFDF9"
                BorderBrush="#C8BFAF"
                BorderThickness="1"
                CornerRadius="12"
                Padding="25">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Заголовок -->
                <TextBlock x:Name="TitleText"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="#2F4F4F"
                           Margin="0,0,0,25"/>

                <!-- Контент -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="600">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Левая часть - форма -->
                        <StackPanel Margin="0,0,25,0">
                            <!-- Название -->
                            <TextBlock Text="Название*" Style="{StaticResource LabelStyle}"/>
                            <TextBox x:Name="TitleBox" Style="{StaticResource TextBoxStyle}" MaxLength="200"/>

                            <!-- АВТОРЫ (множественный выбор) -->
                            <TextBlock Text="Авторы*" Style="{StaticResource LabelStyle}" Margin="0,10,0,0"/>
                            <DockPanel LastChildFill="True" Margin="0,0,0,5">
                                <Button x:Name="AddAuthorButton" 
                                        Content="+" 
                                        Style="{StaticResource SmallButtonStyle}"
                                        DockPanel.Dock="Right"
                                        Margin="5,0,0,0"
                                        Cursor="Hand"
                                        Click="AddAuthor_Click"/>
                                <ComboBox x:Name="AuthorBox" 
                                          Style="{StaticResource ComboBoxStyle}" 
                                          DisplayMemberPath="FullName"
                                          KeyUp="AuthorBox_KeyUp"/>
                            </DockPanel>
                            <TextBlock Text="Выбранные авторы:" Style="{StaticResource SubLabelStyle}"/>
                            <ListBox x:Name="SelectedAuthorsList" 
         Style="{StaticResource ListBoxStyle}"
         DisplayMemberPath="FullName"/>
                            <Button x:Name="RemoveAuthorButton" 
                                    Content="Удалить выбранных авторов"
                                    Style="{StaticResource DangerButtonStyle}"
                                    Margin="0,5,0,0"
                                    Click="RemoveAuthors_Click"/>

                            <!-- ЖАНРЫ (множественный выбор) -->
                            <TextBlock Text="Жанры*" Style="{StaticResource LabelStyle}" Margin="0,15,0,0"/>
                            <DockPanel LastChildFill="True" Margin="0,0,0,5">
                                <Button x:Name="AddGenreButton" 
                                        Content="+" 
                                        Style="{StaticResource SmallButtonStyle}"
                                        DockPanel.Dock="Right"
                                        Margin="5,0,0,0"
                                        Cursor="Hand"
                                        Click="AddGenre_Click"/>
                                <ComboBox x:Name="GenreBox" 
                                          Style="{StaticResource ComboBoxStyle}" 
                                          DisplayMemberPath="Name"
                                          KeyUp="GenreBox_KeyUp"/>
                            </DockPanel>
                            <TextBlock Text="Выбранные жанры:" Style="{StaticResource SubLabelStyle}"/>
                            <ListBox x:Name="SelectedGenresList" 
         Style="{StaticResource ListBoxStyle}"
         DisplayMemberPath="Name"/>
                            <Button x:Name="RemoveGenreButton" 
                                    Content="Удалить выбранные жанры"
                                    Style="{StaticResource DangerButtonStyle}"
                                    Margin="0,5,0,0"
                                    Click="RemoveGenres_Click"/>

                            <!-- Издательство -->
                            <TextBlock Text="Издательство*" Style="{StaticResource LabelStyle}" Margin="0,15,0,0"/>
                            <ComboBox x:Name="PublisherBox" 
                                      Style="{StaticResource ComboBoxStyle}" 
                                      DisplayMemberPath="PublisherName"
                                      KeyUp="PublisherBox_KeyUp"/>

                            <!-- Год издания -->
                            <TextBlock Text="Год издания*" Style="{StaticResource LabelStyle}" Margin="0,10,0,0"/>
                            <TextBox x:Name="YearBox" Style="{StaticResource TextBoxStyle}" MaxLength="4" 
                                     PreviewTextInput="YearBox_PreviewTextInput"/>

                            <!-- ISBN -->
                            <TextBlock Text="ISBN*" Style="{StaticResource LabelStyle}" Margin="0,10,0,0"/>
                            <TextBox x:Name="IsbnBox" Style="{StaticResource TextBoxStyle}" MaxLength="20"/>

                            <!-- Страниц -->
                            <TextBlock Text="Страниц*" Style="{StaticResource LabelStyle}" Margin="0,10,0,0"/>
                            <TextBox x:Name="PagesBox" Style="{StaticResource TextBoxStyle}" 
                                     PreviewTextInput="NumberOnly_PreviewTextInput"/>

                            <!-- Язык -->
                            <TextBlock Text="Язык*" Style="{StaticResource LabelStyle}" Margin="0,10,0,0"/>
                            <ComboBox x:Name="LanguageBox" 
                                      Style="{StaticResource ComboBoxStyle}" 
                                      DisplayMemberPath="LanguageName" 
                                      SelectedValuePath="LanguageId"
                                      KeyUp="LanguageBox_KeyUp"/>

                            <!-- Переплет -->
                            <TextBlock Text="Переплет*" Style="{StaticResource LabelStyle}" Margin="0,10,0,0"/>
                            <ComboBox x:Name="BindingBox" 
                                      Style="{StaticResource ComboBoxStyle}" 
                                      DisplayMemberPath="BindingName"
                                      SelectedValuePath="BindingId"
                                      KeyUp="BindingBox_KeyUp"/>

                            <!-- Формат -->
                            <TextBlock Text="Формат*" Style="{StaticResource LabelStyle}" Margin="0,10,0,0"/>
                            <TextBox x:Name="FormatBox" Style="{StaticResource TextBoxStyle}" MaxLength="50"/>
                            <TextBlock Text="Примеры: 84x108/32, 60x90/16, 70x100/16"
                                       FontSize="10" Foreground="#999" Margin="2,2,0,10"/>

                            <!-- Серия -->
                            <TextBlock Text="Серия*" Style="{StaticResource LabelStyle}" Margin="0,10,0,0"/>
                            <TextBox x:Name="SeriesBox" Style="{StaticResource TextBoxStyle}" MaxLength="100"/>
                            <TextBlock Text="Примеры: Русская классика, Мировая классика, Фантастика и фэнтези"
                                       FontSize="10" Foreground="#999" Margin="2,2,0,10"/>

                            <!-- Издание -->
                            <TextBlock Text="Издание*" Style="{StaticResource LabelStyle}" Margin="0,10,0,0"/>
                            <TextBox x:Name="EditionBox" Style="{StaticResource TextBoxStyle}" MaxLength="50"/>
                            <TextBlock Text="Примеры: 1-е, 2-е переработанное, 3-е стереотипное"
                                       FontSize="10" Foreground="#999" Margin="2,2,0,10"/>

                            <!-- Тираж -->
                            <TextBlock Text="Тираж*" Style="{StaticResource LabelStyle}" Margin="0,10,0,0"/>
                            <TextBox x:Name="CirculationBox" Style="{StaticResource TextBoxStyle}" 
                                     PreviewTextInput="NumberOnly_PreviewTextInput"/>

                            <!-- Количество экземпляров -->
                            <TextBlock Text="Количество экземпляров*" Style="{StaticResource LabelStyle}" Margin="0,10,0,0"/>
                            <TextBox x:Name="QuantityBox" Style="{StaticResource TextBoxStyle}" Text="1"
                                     PreviewTextInput="NumberOnly_PreviewTextInput"/>

                            <!-- Описание -->
                            <TextBlock Text="Описание*" Style="{StaticResource LabelStyle}" Margin="0,10,0,0"/>
                            <TextBox x:Name="DescriptionBox" Style="{StaticResource MultiLineTextBoxStyle}" 
                                     MaxLength="4000"/>
                        </StackPanel>

                        <!-- Правая часть - обложка -->
                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                            <Border Width="150" Height="220"
                                    Background="#F4F1EC"
                                    BorderBrush="#C8BFAF"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="6">
                                <Image x:Name="CoverImage"
                                       Stretch="Uniform"
                                       SnapsToDevicePixels="True"/>
                            </Border>

                            <Button Content="Загрузить обложку"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Margin="0,15,0,0"
                                    Click="LoadImage_Click" Width="180"/>

                            <Button Content="Удалить обложку"
                                    Style="{StaticResource DangerButtonStyle}"
                                    Margin="0,10,0,0"
                                    Click="RemoveImage_Click" Width="180"/>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>

                <!-- Кнопки внизу -->
                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,25,0,0">
                    <Button Content="Сохранить"
                            Width="130"
                            Margin="0,0,10,0"
                            Style="{StaticResource ActionButtonStyle}"
                            Click="Save_Click"/>
                    <Button Content="Отмена"
                            Width="110"
                            Style="{StaticResource ActionButtonStyle}"
                            Background="#6F6F6F"
                            Click="Cancel_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>