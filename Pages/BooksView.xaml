<Page x:Class="LibraryAccounting.Pages.BooksView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:conv="clr-namespace:LibraryAccounting.Converters"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d"
      d:DesignHeight="600"
      d:DesignWidth="1200"
      Background="#F4F1EC">

    <Page.Resources>
        <conv:ByteArrayToImageConverter x:Key="ByteArrayToImageConverter"/>

        <Style x:Key="DeleteButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#5F3E40"/>
            <Setter Property="BorderBrush" Value="#4A2F30"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4A2F30"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для ComboBox с поиском -->
        <Style x:Key="SearchComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="#F4F1EC"/>
            <Setter Property="BorderBrush" Value="#C8BFAF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="IsEditable" Value="True"/>
            <Setter Property="IsTextSearchEnabled" Value="False"/>
            <Setter Property="StaysOpenOnEdit" Value="True"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="#FFFDF9"
                BorderBrush="#C8BFAF"
                BorderThickness="1"
                CornerRadius="8"
                Padding="20"
                Margin="0,0,0,20">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Каталог книг"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="#2F4F4F"/>

                    <TextBlock Text="Управление библиотечным фондом"
                               FontSize="13"
                               Foreground="#6F6F6F"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <Button Content="Добавить" Click="AddButton_Click"
                            Width="100"
                            Margin="0,0,10,0"
                            Style="{StaticResource ActionButtonStyle}"/>

                    <Button x:Name="DeleteButton" Content="Удалить" Click="DeleteButton_Click"
                            Width="100"
                            Margin="0,0,10,0"
                            Style="{StaticResource DeleteButtonStyle}"/>

                    <Button Content="Экспорт CSV" Click="ExportToCsv_Click"
                            Width="120"
                            Margin="0,0,0,0"
                            Style="{StaticResource ActionButtonStyle}"/>

                    <Button Content="Аналитика" Click="Analytics_Click"
                            Width="120"
                            Margin="10,0,0,0"
                            Style="{StaticResource ActionButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Таблица книг -->
        <Border Grid.Row="1"
                Background="#FFFDF9"
                BorderBrush="#C8BFAF"
                BorderThickness="1"
                CornerRadius="8"
                Padding="15">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Поиск и фильтры -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="Поиск:"
                               VerticalAlignment="Center"
                               Foreground="#3A3A3A"
                               Margin="0,0,10,0"/>

                    <TextBox x:Name="SearchTextBox"
                             Width="250"
                             Height="32"
                             Padding="8"
                             Background="#F4F1EC"
                             BorderBrush="#C8BFAF"
                             BorderThickness="1"
                             TextChanged="SearchTextBox_TextChanged"/>

                    <!-- Фильтр по жанру (с поиском) -->
                    <ComboBox x:Name="GenreComboBox"
          Width="180"
          Margin="20,0,0,0"
          SelectionChanged="GenreFilter_Changed"
          KeyUp="GenreComboBox_KeyUp"
          IsEditable="True"
          IsTextSearchEnabled="False"
          StaysOpenOnEdit="True"/>

                    <!-- Фильтр по издательству (с поиском) -->
                    <ComboBox x:Name="PublisherComboBox"
          Width="180"
          Margin="10,0,0,0"
          SelectionChanged="PublisherFilter_Changed"
          KeyUp="PublisherComboBox_KeyUp"
          IsEditable="True"
          IsTextSearchEnabled="False"
          StaysOpenOnEdit="True"/>

                    <!-- Сортировка -->
                    <ComboBox x:Name="SortComboBox"
                              Width="180"
                              Margin="10,0,0,0"
                              SelectionChanged="SortComboBox_SelectionChanged">
                        <ComboBoxItem Content="Без сортировки"/>
                        <ComboBoxItem Content="По названию"/>
                        <ComboBoxItem Content="По автору"/>
                        <ComboBoxItem Content="По году"/>
                        <ComboBoxItem Content="По количеству"/>
                    </ComboBox>
                </StackPanel>

                <DataGrid x:Name="BooksDataGrid"
                          Grid.Row="1"
                          RowHeight="130"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          FrozenColumnCount="2"
                          Style="{StaticResource BooksDataGridStyle}"
                          ColumnHeaderStyle="{StaticResource BooksDataGridColumnHeaderStyle}"
                          RowStyle="{StaticResource BooksDataGridRowStyle}"
                          CellStyle="{StaticResource BooksDataGridCellStyle}"
                          AutoGenerateColumns="False"
                          MouseDoubleClick="BooksDataGrid_MouseDoubleClick">

                    <DataGrid.Columns>
                        <!-- Обложка -->
                        <DataGridTemplateColumn Header="Обложка" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Width="70" Height="100"
                                            CornerRadius="6"
                                            BorderBrush="#C8BFAF"
                                            BorderThickness="1"
                                            Background="#F4F1EC">
                                        <Image Source="{Binding CoverImage, Converter={StaticResource ByteArrayToImageConverter}}"
                                               Stretch="UniformToFill"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Основная информация -->
                        <DataGridTextColumn Header="Название" Binding="{Binding Title}" Width="250"/>
                        <DataGridTextColumn Header="Автор" Binding="{Binding AuthorName}" Width="200"/>
                        <DataGridTextColumn Header="Жанр" Binding="{Binding GenreName}" Width="150"/>
                        <DataGridTextColumn Header="Издательство" Binding="{Binding PublisherName}" Width="180"/>
                        <DataGridTextColumn Header="Год" Binding="{Binding PublishYear}" Width="80"/>
                        <DataGridTextColumn Header="ISBN" Binding="{Binding ISBN}" Width="150"/>

                        <!-- Физические характеристики -->
                        <DataGridTextColumn Header="Страниц" Binding="{Binding Pages}" Width="80"/>
                        <DataGridTextColumn Header="Язык" Binding="{Binding LanguageName}" Width="100"/>
                        <DataGridTextColumn Header="Переплет" Binding="{Binding BindingName}" Width="100"/>
                        <DataGridTextColumn Header="Формат" Binding="{Binding Format}" Width="100"/>

                        <!-- Издание -->
                        <DataGridTextColumn Header="Серия" Binding="{Binding Series}" Width="150"/>
                        <DataGridTextColumn Header="Издание" Binding="{Binding Edition}" Width="100"/>
                        <DataGridTextColumn Header="Тираж" Binding="{Binding Circulation}" Width="100"/>

                        <!-- Количество -->
                        <DataGridTextColumn Header="Экз. (всего)" Binding="{Binding TotalCopies}" Width="80"/>
                        <DataGridTextColumn Header="Экз. (доступно)" Binding="{Binding AvailableCopies}" Width="90"/>

                        <!-- Даты -->
                        <DataGridTextColumn Header="Дата добавления" Binding="{Binding AddedDate, StringFormat=d}" Width="120"/>
                        <DataGridTextColumn Header="Изменено" Binding="{Binding LastModified, StringFormat=d}" Width="120"/>

                        <!-- Описание (широкое поле) -->
                        <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="300"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Page>