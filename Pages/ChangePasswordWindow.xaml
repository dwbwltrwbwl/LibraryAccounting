<Window x:Class="LibraryAccounting.Pages.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LibraryAccounting.Pages"
        mc:Ignorable="d"
        Title="Смена пароля"
        Height="450"
        Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F4F1EC">

    <Window.Resources>
        <!-- Стиль для кнопок -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2F4F4F"/>
            <Setter Property="BorderBrush" Value="#1F3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1F3A3A"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#0F2A2A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для второстепенных кнопок -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#FFFDF9"/>
            <Setter Property="Foreground" Value="#2F4F4F"/>
            <Setter Property="BorderBrush" Value="#C8BFAF"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F4F1EC"/>
                    <Setter Property="BorderBrush" Value="#2F4F4F"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для полей ввода -->
        <Style x:Key="InputBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#F4F1EC"/>
            <Setter Property="BorderBrush" Value="#C8BFAF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Margin" Value="0,6,0,16"/>
        </Style>
    </Window.Resources>

    <Border Padding="30"
            Background="#FFFDF9"
            CornerRadius="12"
            BorderBrush="#C8BFAF"
            BorderThickness="1">

        <StackPanel>

            <TextBlock Text="Смена пароля"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="#2F4F4F"
                       Margin="0,0,0,8"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="Укажите новый пароль"
                       FontSize="13"
                       Foreground="#6F6F6F"
                       Margin="0,0,0,24"
                       HorizontalAlignment="Center"/>

            <!-- Новый пароль -->
            <TextBlock Text="Новый пароль"
                       FontWeight="SemiBold"
                       Foreground="#3A3A3A"/>

            <TextBlock Text="(мин. 6 символов, буквы разного регистра, цифры, спец. символы)"
                       FontSize="10"
                       Foreground="#999"
                       Margin="0,2,0,0"/>

            <Border Style="{StaticResource InputBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <PasswordBox x:Name="NewPasswordBox"
                                 Height="36"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="10"
                                 FontSize="14"
                                 MaxLength="50"
                                 PasswordChanged="NewPasswordBox_PasswordChanged"/>
                    <Button x:Name="ToggleNewPasswordBtn"
                            Grid.Column="1"
                            Content="👁️"
                            Width="30"
                            Height="30"
                            Margin="0,0,5,0"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontSize="14"
                            Click="ToggleNewPassword_Click"/>
                </Grid>
            </Border>

            <!-- Индикатор сложности пароля -->
            <Border x:Name="PasswordStrengthBorder"
                    Background="#F4F1EC"
                    CornerRadius="5"
                    Padding="10,5"
                    Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Сложность пароля:"
                               Foreground="#2F4F4F"
                               FontSize="11"
                               Margin="0,0,10,0"/>
                    <TextBlock x:Name="PasswordStrengthText"
                               Grid.Column="1"
                               Text=""
                               FontSize="11"
                               FontWeight="SemiBold"/>
                </Grid>
            </Border>

            <!-- Подтверждение пароля -->
            <TextBlock Text="Подтверждение пароля"
                       FontWeight="SemiBold"
                       Foreground="#3A3A3A"/>

            <Border Style="{StaticResource InputBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <PasswordBox x:Name="ConfirmPasswordBox"
                                 Height="36"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="10"
                                 FontSize="14"
                                 MaxLength="50"
                                 PasswordChanged="ConfirmPasswordBox_PasswordChanged"/>
                    <Button x:Name="ToggleConfirmPasswordBtn"
                            Grid.Column="1"
                            Content="👁️"
                            Width="30"
                            Height="30"
                            Margin="0,0,5,0"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontSize="14"
                            Click="ToggleConfirmPassword_Click"/>
                </Grid>
            </Border>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,10,0,0">

                <Button Content="Отмена"
                        Width="100"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="Cancel_Click"/>

                <Button x:Name="SaveButton"
                        Content="Сохранить"
                        Width="120"
                        Style="{StaticResource ActionButtonStyle}"
                        Click="Save_Click"
                        IsEnabled="False"
                        Opacity="0.6"/>
            </StackPanel>

        </StackPanel>
    </Border>
</Window>