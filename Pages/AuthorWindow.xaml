<Window x:Class="LibraryAccounting.Pages.AuthorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LibraryAccounting.Pages"
        mc:Ignorable="d"
        Title="Автор" Height="650" Width="600"
        WindowStartupLocation="CenterOwner"
        Background="#F4F1EC">

    <Window.Resources>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2F4F4F"/>
            <Setter Property="BorderBrush" Value="#1F3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1F3A3A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CancelButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2F4F4F"/>
            <Setter Property="Background" Value="#FFFDF9"/>
            <Setter Property="BorderBrush" Value="#C8BFAF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0EDE8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TextFieldStyle" TargetType="TextBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Background" Value="#FFFDF9"/>
            <Setter Property="BorderBrush" Value="#C8BFAF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#2F4F4F"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="10,0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#2F4F4F"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Background" Value="#FFFDF9"/>
            <Setter Property="BorderBrush" Value="#C8BFAF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Foreground" Value="#2F4F4F"/>
        </Style>

        <!-- Стиль для DatePicker -->
        <Style x:Key="DatePickerStyle" TargetType="DatePicker">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Background" Value="#FFFDF9"/>
            <Setter Property="BorderBrush" Value="#C8BFAF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#2F4F4F"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePicker">
                        <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <DatePickerTextBox x:Name="TextBox" 
                                           Grid.Column="0"
                                           VerticalContentAlignment="Center"
                                           Background="Transparent"
                                           BorderThickness="0"
                                           Margin="10,0,0,0"/>

                                <Button x:Name="Button"
                                Grid.Column="1"
                                Content="📅"
                                Width="35"
                                Height="35"
                                Background="Transparent"
                                BorderThickness="0"
                                FontSize="14"
                                Cursor="Hand"
                                Focusable="False"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2F4F4F"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="ErrorTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#D32F2F"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </Window.Resources>

    <Border Background="#FFFDF9"
            BorderBrush="#C8BFAF"
            BorderThickness="1"
            CornerRadius="10"
            Margin="15">

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Заголовок -->
                <TextBlock Text="Добавление / Редактирование автора"
                           x:Name="TitleText"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#2F4F4F"
                           Margin="0,0,0,20"/>

                <!-- ФИО -->
                <TextBlock Text="ФИО*" Grid.Row="1" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="NameBox" 
                         Grid.Row="2" 
                         Style="{StaticResource TextFieldStyle}"
                         MaxLength="200"
                         TextChanged="NameBox_TextChanged"/>

                <!-- Дата рождения -->
                <TextBlock Text="Дата рождения*" Grid.Row="3" Style="{StaticResource LabelStyle}" Margin="0,15,0,0"/>
                <DatePicker x:Name="BirthDatePicker" 
            Grid.Row="4" 
            Height="35"
            SelectedDateChanged="BirthDatePicker_SelectedDateChanged">
                    <DatePicker.Resources>
                        <Style TargetType="DatePickerTextBox">
                            <Setter Property="IsReadOnly" Value="True"/>
                            <Setter Property="Background" Value="#FFFDF9"/>
                            <Setter Property="BorderBrush" Value="#C8BFAF"/>
                        </Style>
                    </DatePicker.Resources>
                </DatePicker>

                <!-- Дата смерти -->
                <TextBlock Text="Дата смерти" Grid.Row="5" Style="{StaticResource LabelStyle}" Margin="0,15,0,0"/>
                <DatePicker x:Name="DeathDatePicker" 
            Grid.Row="6" 
            Height="35"
            SelectedDateChanged="DeathDatePicker_SelectedDateChanged">
                    <DatePicker.Resources>
                        <Style TargetType="DatePickerTextBox">
                            <Setter Property="IsReadOnly" Value="True"/>
                            <Setter Property="Background" Value="#FFFDF9"/>
                            <Setter Property="BorderBrush" Value="#C8BFAF"/>
                        </Style>
                    </DatePicker.Resources>
                </DatePicker>
                <!-- Страна (выпадающий список с поиском) -->
                <TextBlock Text="Страна" Grid.Row="7" Style="{StaticResource LabelStyle}" Margin="0,15,0,0"/>
                <ComboBox x:Name="CountryComboBox" 
          Grid.Row="8" 
          Style="{StaticResource ComboBoxStyle}"
          DisplayMemberPath="CountryName"
          SelectedValuePath="CountryId"
          IsEditable="True"
          IsTextSearchEnabled="True"
          TextSearch.TextPath="CountryName"
          StaysOpenOnEdit="True"
          SelectionChanged="CountryComboBox_SelectionChanged"
          KeyUp="CountryComboBox_KeyUp"/>

                <!-- Город (выпадающий список, зависит от страны) -->
                <TextBlock Text="Город" Grid.Row="9" Style="{StaticResource LabelStyle}" Margin="0,15,0,0"/>
                <ComboBox x:Name="CityComboBox" 
                          Grid.Row="10" 
                          Style="{StaticResource ComboBoxStyle}"
                          DisplayMemberPath="CityName"
                          SelectedValuePath="CityId"
                          IsEnabled="False"/>

                <!-- Блок для ошибок -->
                <TextBlock x:Name="ErrorTextBlock" 
                           Grid.Row="11"
                           Style="{StaticResource ErrorTextStyle}"
                           Visibility="Collapsed"/>

                <!-- Кнопки -->
                <StackPanel Grid.Row="12"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,20,0,0">
                    <Button Content="Сохранить" 
                            Width="120"
                            Style="{StaticResource ActionButtonStyle}"
                            Click="Save_Click"/>
                    <Button Content="Отмена" 
                            Width="120"
                            Style="{StaticResource CancelButtonStyle}"
                            Click="Cancel_Click"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Border>
</Window>